---
import { business } from '../data/business';
---

<header class="header" id="top">
  <div class="container header-inner">
    <a href="#top" class="logo">
      <span class="logo-icon">
        <svg aria-hidden="true" viewBox="0 0 28 28" width="28" height="28" fill="none">
          <rect width="28" height="28" rx="6" fill="#1e5ea6"/>
          <path d="M6 19V9l4.5 5L15 9v10M15 9l4.5 5L24 9v10" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
      <span class="logo-text">Sécurité</span>
    </a>
    <a href={`tel:${business.phone}`} class="header-phone" aria-label="Appeler">
      <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
      <span class="header-phone-text">{business.phoneDisplay}</span>
    </a>
    <nav class="nav" aria-label="Navigation principale">
      <button class="nav-toggle" aria-label="Menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
      <ul class="nav-list">
        <li><a href="#services">Services</a></li>
        <li><a href="#commerces">Commerces</a></li>
        <li><a href="/a-propos">À propos</a></li>
        <li><a href="#faq">FAQ</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/devis-gratuit" class="btn btn-nav">Devis gratuit</a></li>
      </ul>
    </nav>
  </div>
</header>
