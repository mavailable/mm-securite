---
/**
 * Schema.org JSON-LD — LocalBusiness + WebSite + BreadcrumbList + Speakable
 * Doctrine C1 : helpers centralises dans src/data/schemas.ts
 * Ce composant est un simple injecteur pour la homepage.
 */
import { business } from '@data/business';
import {
  getLocalBusinessSchema,
  getWebsiteSchema,
  getBreadcrumbSchema,
  getSpeakableSchema,
} from '@data/schemas';

const localBusinessSchema = getLocalBusinessSchema();
const websiteSchema = getWebsiteSchema();
const breadcrumbSchema = getBreadcrumbSchema([
  { name: 'Accueil', url: business.siteUrl },
]);
const speakableSchema = getSpeakableSchema(
  business.seo.defaultTitle,
  business.seo.defaultDescription,
  business.siteUrl
);
---

<script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(speakableSchema)} />
