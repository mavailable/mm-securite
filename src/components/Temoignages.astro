---
import { business } from '../data/business';

const starSvg = '<svg aria-hidden="true" viewBox="0 0 20 20" fill="#f59e0b" width="16" height="16"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>';
const fiveStars = Array(5).fill(starSvg).join('');
---

<section class="temoignages" id="avis">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">Avis clients</span>
      <h2>Ce que disent<br /><strong>mes clients</strong></h2>
    </div>
    <div class="temoignages-grid">
      {business.reviews.map(review => (
        <blockquote class="temoignage-card">
          <div class="temoignage-stars" aria-label={`${review.rating} étoiles`}>
            <Fragment set:html={fiveStars} />
          </div>
          <p class="temoignage-text">{review.text}</p>
          <footer class="temoignage-author">
            <div class="temoignage-avatar">{review.initial}</div>
            <div>
              <strong>{review.author}</strong>
              <span>{review.role}</span>
            </div>
          </footer>
        </blockquote>
      ))}
    </div>
    <p class="temoignage-note">Ces témoignages reflètent l'expérience de clients réels. Les prénoms ont été modifiés par souci de confidentialité.</p>
  </div>
</section>
