---
/**
 * ContactForm — Formulaire de devis Web3Forms réutilisable
 * Utilisé dans Contact.astro (homepage) et /devis-gratuit
 */
import { business } from '@data/business';

interface Props {
  darkMode?: boolean;
}

const { darkMode = false } = Astro.props;

const commerceOptions = business.commerceTypes;
const serviceOptions = business.services.map(s => s.name);

const inputClass = darkMode
  ? 'w-full px-4 py-3 rounded-DEFAULT bg-white/10 border border-white/20 text-white placeholder-white/40 focus:border-accent-400 focus:ring-2 focus:ring-accent-400/30 focus:outline-none transition-colors min-h-[44px] text-base'
  : 'w-full px-4 py-3 rounded-DEFAULT bg-white border border-neutral-300 text-neutral-900 placeholder-neutral-400 focus:border-accent-500 focus:ring-2 focus:ring-accent-500/30 focus:outline-none transition-colors min-h-[44px] text-base';

const labelClass = darkMode
  ? 'block text-sm text-white/90 mb-1 font-medium'
  : 'block text-sm text-neutral-700 mb-1 font-medium';

const selectOptionClass = 'text-neutral-900';
---

<form action="https://api.web3forms.com/submit" method="POST" class="space-y-4" id="contact-form">
  <input type="hidden" name="access_key" value={business.web3formsKey} />
  <input type="hidden" name="subject" value="Nouveau message depuis mm-securite.fr" />
  <input type="hidden" name="from_name" value="MM Sécurité — Formulaire" />
  <input type="hidden" name="redirect" value={`${business.siteUrl}/merci`} />
  <input type="checkbox" name="botcheck" class="hidden" style="display: none;" tabindex="-1" autocomplete="off" />

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <label for="name" class={labelClass}>Votre prénom <span class="text-red-400">*</span></label>
      <input type="text" name="name" id="name" required aria-required="true" class={inputClass} placeholder="Marc" />
    </div>
    <div>
      <label for="phone" class={labelClass}>Votre téléphone <span class="text-red-400">*</span></label>
      <input type="tel" name="phone" id="phone" required aria-required="true" class={inputClass} placeholder="06 12 34 56 78" />
    </div>
  </div>

  <div>
    <label for="email" class={labelClass}>Votre email</label>
    <input type="email" name="email" id="email" class={inputClass} placeholder="marc@exemple.fr" />
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <label for="commerce" class={labelClass}>Type de commerce <span class="text-red-400">*</span></label>
      <select name="commerce" id="commerce" required aria-required="true" class={inputClass}>
        <option value="" class={selectOptionClass}>Choisir...</option>
        {commerceOptions.map(opt => (
          <option value={opt} class={selectOptionClass}>{opt}</option>
        ))}
        <option value="Autre" class={selectOptionClass}>Autre</option>
      </select>
    </div>
    <div>
      <label for="service" class={labelClass}>Service souhaité <span class="text-red-400">*</span></label>
      <select name="service" id="service" required aria-required="true" class={inputClass}>
        <option value="" class={selectOptionClass}>Choisir...</option>
        {serviceOptions.map(opt => (
          <option value={opt} class={selectOptionClass}>{opt}</option>
        ))}
        <option value="Autre" class={selectOptionClass}>Autre</option>
      </select>
    </div>
  </div>

  <div>
    <label for="message" class={labelClass}>Votre message</label>
    <textarea name="message" id="message" rows="4" class={`${inputClass} resize-y`} placeholder="Décrivez votre besoin..."></textarea>
  </div>

  <div class="flex items-start gap-2">
    <input type="checkbox" name="rgpd" id="rgpd" required aria-required="true" class="mt-1 w-4 h-4 rounded accent-accent-500" />
    <label for="rgpd" class={`text-xs leading-relaxed ${darkMode ? 'text-white/90' : 'text-neutral-600'}`}>
      En soumettant ce formulaire, vous acceptez que vos données soient traitées conformément à notre
      <a href="/politique-de-confidentialite" class={`underline ${darkMode ? 'hover:text-accent-400' : 'hover:text-accent-600'}`}>politique de confidentialité</a>.
      Vos données ne seront jamais partagées avec des tiers.
    </label>
  </div>

  <button
    type="submit"
    class="w-full sm:w-auto bg-accent-600 hover:bg-accent-700 text-white font-semibold py-3.5 px-8 rounded-DEFAULT min-h-[44px] transition-colors text-lg disabled:opacity-50 disabled:cursor-not-allowed"
  >
    Envoyer ma demande de devis
  </button>
</form>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement;

  form?.addEventListener('submit', () => {
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Envoi en cours...';
    }
  });
</script>
