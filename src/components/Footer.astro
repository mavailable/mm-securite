---
import { business } from '../data/business';
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="#top" class="logo">
          <span class="logo-icon">
            <svg aria-hidden="true" viewBox="0 0 28 28" width="24" height="24" fill="none">
              <rect width="28" height="28" rx="6" fill="#4a9bdf"/>
              <path d="M6 19V9l4.5 5L15 9v10M15 9l4.5 5L24 9v10" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <span class="logo-text" style="color:#fff">Sécurité</span>
        </a>
        <p>{business.legalName} — Systèmes de sécurité<br />pour commerces à {business.address.city} et {business.address.region}</p>
      </div>
      <nav class="footer-nav" aria-label="Pied de page">
        <div class="footer-col">
          <h4>Navigation</h4>
          <a href="#services">Services</a>
          <a href="/a-propos">À propos</a>
          <a href="/devis-gratuit">Devis gratuit</a>
          <a href="#faq">FAQ</a>
          <a href="/blog">Blog</a>
          <a href="#contact">Contact</a>
        </div>
        <div class="footer-col">
          <h4>Services</h4>
          {business.services.filter(s => s.slug).map(s => (
            <a href={s.slug}>{s.name}</a>
          ))}
        </div>
      </nav>
    </div>
    <div class="footer-bottom">
      <div class="footer-legal-links">
        <a href="/mentions-legales">Mentions légales</a>
        <span>·</span>
        <a href="/politique-de-confidentialite">Politique de confidentialité</a>
      </div>
      <p>&copy; {new Date().getFullYear()} {business.name} — {business.legalName} — SIRET {business.siret} — Tous droits réservés</p>
      <p style="font-size:0.75rem;opacity:0.85;margin-top:0.5rem;"><a href={business.credit.url} style="color:inherit;text-decoration:none;" target="_blank" rel="noopener noreferrer">{business.credit.text}</a></p>
    </div>
  </div>
</footer>
