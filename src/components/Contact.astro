---
import { business } from '../data/business';
---

<section class="contact" id="contact">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">Contact</span>
      <h2>Un projet ? Une question ?<br /><strong>Parlons-en.</strong></h2>
      <p class="section-intro">Décrivez votre besoin, je vous rappelle sous <strong>48 heures</strong> avec une proposition adaptée.</p>
    </div>

    <div class="contact-grid">
      <form class="contact-form" id="contact-form">
        <input type="hidden" name="access_key" value={business.web3formsKey} />
        <input type="hidden" name="subject" value="Nouveau message depuis mm-securite.fr" />
        <input type="hidden" name="from_name" value="MM Sécurité - Formulaire" />
        <input type="hidden" name="replyto" value="email" />
        <input type="hidden" name="autoreply" value={`Bonjour, merci pour votre demande ! Je l'ai bien reçue et je vous recontacte sous 48 heures avec une proposition personnalisée. À très vite — ${business.owner}, ${business.name} | ${business.phoneDisplay}`} />
        <input type="checkbox" name="botcheck" class="hidden" style="display:none" />

        <div class="form-row">
          <div class="form-group">
            <label for="nom">Nom *</label>
            <input type="text" id="nom" name="nom" placeholder="Votre nom" required autocomplete="name" />
          </div>
          <div class="form-group">
            <label for="telephone">Téléphone *</label>
            <input type="tel" id="telephone" name="telephone" placeholder="06 12 34 56 78" required autocomplete="tel" />
          </div>
        </div>

        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" placeholder="vous@exemple.fr" autocomplete="email" />
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="commerce">Type de commerce</label>
            <select id="commerce" name="commerce">
              <option value="">-- Votre activité --</option>
              <option value="boulangerie">Boulangerie / Pâtisserie</option>
              <option value="restaurant">Restaurant / Bar</option>
              <option value="salon">Salon de coiffure / beauté</option>
              <option value="boutique">Boutique / Magasin</option>
              <option value="pharmacie">Pharmacie</option>
              <option value="cabinet">Cabinet médical</option>
              <option value="hotel">Hôtel / Hébergement</option>
              <option value="salle-sport">Salle de sport</option>
              <option value="bureau">Bureau / Coworking</option>
              <option value="autre">Autre</option>
            </select>
          </div>
          <div class="form-group">
            <label for="service">Besoin principal</label>
            <select id="service" name="service">
              <option value="">-- Service souhaité --</option>
              <option value="alarme-intrusion">Alarme intrusion</option>
              <option value="alarme-incendie">Alarme incendie / SSI</option>
              <option value="videosurveillance">Vidéosurveillance</option>
              <option value="controle-acces">Contrôle d'accès</option>
              <option value="plan-evacuation">Plan d'évacuation</option>
              <option value="mise-en-conformite">Mise en conformité ERP</option>
              <option value="pack-complet">Pack complet sécurité</option>
              <option value="sous-traitance">Sous-traitance (pro)</option>
            </select>
          </div>
        </div>

        <div class="form-group">
          <label for="message">Décrivez votre besoin *</label>
          <textarea id="message" name="message" rows="4" placeholder="Décrivez votre projet, la taille de vos locaux, vos contraintes…" required></textarea>
        </div>

        <p class="form-rgpd" style="font-size:0.8rem;color:var(--gray-500);margin-bottom:1rem;line-height:1.5;">
          En soumettant ce formulaire, vous acceptez que vos données soient traitées conformément à notre
          <a href="/politique-de-confidentialite" style="color:var(--blue-600);text-decoration:underline;">politique de confidentialité</a>.
          Vos données ne seront jamais partagées avec des tiers.
        </p>
        <button type="submit" class="btn btn-primary btn-submit" id="submit-btn">
          <span class="btn-text">Envoyer ma demande</span>
          <span class="btn-loading" style="display:none">Envoi en cours…</span>
          <svg aria-hidden="true" class="btn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </button>
        <p class="form-note">Gratuit & sans engagement — réponse sous 48h</p>
      </form>

      <div class="form-success" id="form-success" role="status" aria-live="polite" style="display:none">
        <div class="success-icon">
          <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" width="48" height="48"><path d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <h3>Message envoyé !</h3>
        <p>Merci pour votre demande. Je vous recontacte sous <strong>48 heures</strong>.</p>
        <button class="btn btn-ghost" id="reset-form">Envoyer un autre message</button>
      </div>

      <div class="contact-sidebar">
        <div class="contact-card">
          <div class="contact-avatar">M</div>
          <h3>{business.owner}</h3>
          <p class="contact-role">{business.ownerRole}</p>
          <div class="contact-links">
            <a href={`mailto:${business.email}`} class="contact-link">
              <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20"><path d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
              {business.email}
            </a>
            <a href={`tel:${business.phone}`} class="contact-link">
              <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20"><path d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
              {business.phoneDisplay}
            </a>
            <div class="contact-link">
              <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20"><path d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
              {business.address.city}, Moselle
            </div>
          </div>
        </div>

        <div class="hours-card">
          <h4>Disponibilités</h4>
          <div class="hours-row"><span>Lundi – Vendredi</span><strong>{business.hours.weekdays}</strong></div>
          <div class="hours-row"><span>Samedi</span><strong>{business.hours.saturday}</strong></div>
          <div class="hours-row hours-highlight"><span>Urgence</span><strong>Me contacter</strong></div>
        </div>
      </div>
    </div>
  </div>
</section>
