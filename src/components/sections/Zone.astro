---
/** Zone d'intervention */
import { Image } from 'astro:assets';
import { business } from '@data/business';
import carteIntervention from '@/assets/images/carte-intervention.jpg';

const cityPages = [
  { name: 'Metz', href: '/securite-commerce-metz', desc: 'Siège, interventions prioritaires' },
  { name: 'Thionville', href: '/securite-commerce-thionville', desc: 'Nord Moselle, bassin frontalier' },
  { name: 'Nancy', href: '/securite-commerce-nancy', desc: 'Meurthe-et-Moselle' },
  { name: 'Forbach', href: '/securite-commerce-forbach', desc: 'Bassin houiller' },
  { name: 'Sarreguemines', href: '/securite-commerce-sarreguemines', desc: 'Est Moselle' },
];
---

<section class="py-12 md:py-16 bg-primary-50">
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
      <div class="reveal">
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-primary-900 mb-4">
          Basé à Metz, j'interviens dans tout le Grand Est
        </h2>
        <p class="text-neutral-600 mb-6">
          Moselle, Meurthe-et-Moselle et au-delà — je me déplace aussi au Luxembourg pour les entreprises frontalières.
        </p>
        <div class="flex flex-wrap gap-2">
          {cityPages.map(city => (
            <a href={city.href} class="inline-flex items-center gap-1.5 bg-white border border-primary-200 text-primary-700 hover:border-primary-400 hover:text-primary-900 px-4 py-2 rounded-DEFAULT text-sm font-medium transition-colors min-h-[44px]">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              {city.name}
            </a>
          ))}
        </div>
      </div>

      <div class="reveal-right">
        <Image
          src={carteIntervention}
          alt="Carte d'intervention MM Sécurité — Metz, Thionville, Nancy, Forbach, Sarreguemines, Grand Est et Luxembourg"
          class="w-full h-auto rounded-DEFAULT shadow-md"
          width={800}
          height={800}
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>
