---
/** Services — cards avec photo + icône overlay */
import { Image } from 'astro:assets';
import { business } from '@data/business';

import imgAlarme from '@/assets/images/service-alarme.jpg';
import imgIncendie from '@/assets/images/service-incendie.jpg';
import imgVideo from '@/assets/images/service-video.jpg';
import imgAcces from '@/assets/images/service-acces.jpg';
import imgEvacuation from '@/assets/images/service-evacuation.jpg';
import imgConformite from '@/assets/images/service-conformite.jpg';

const serviceImages: Record<string, ImageMetadata> = {
  'Alarme intrusion': imgAlarme,
  'Alarme incendie': imgIncendie,
  'Vidéosurveillance': imgVideo,
  "Contrôle d'accès": imgAcces,
  "Plans d'évacuation": imgEvacuation,
  'Mise en conformité ERP': imgConformite,
};

const serviceDescriptions: Record<string, string> = {
  'Alarme intrusion': "Détection volumétrique, sirène, alerte smartphone, levée de doute vidéo. Matériel professionnel.",
  'Alarme incendie': "Détection incendie conforme ERP. Centrale SSI, vérification annuelle, registre de sécurité.",
  'Vidéosurveillance': "Caméras IP HD, vision nocturne, accès distant. Installation 100% conforme RGPD.",
  "Contrôle d'accès": "Badges, digicodes, biométrie. Gérez qui entre et quand dans vos zones sensibles.",
  "Plans d'évacuation": "Plans NF X 08-070, balisage, signalétique. Prêt pour la commission de sécurité.",
  'Mise en conformité ERP': "Audit complet et mise aux normes pour les petits ERP catégories 4 et 5.",
};

const tagColors: Record<string, string> = {
  blue: 'bg-primary-100 text-primary-700',
  red: 'bg-red-100 text-red-700',
};
---

<section id="services" class="py-16 md:py-24 bg-white">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center mb-12 reveal">
      <h2 class="text-2xl md:text-4xl font-heading font-bold text-primary-900 mb-3">
        Ce que j'installe et ce que je maintiens
      </h2>
      <p class="text-neutral-600 max-w-2xl mx-auto">
        Alarme, vidéo, incendie, contrôle d'accès — tout ce qu'il faut pour sécuriser votre commerce et passer la commission de sécurité.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto reveal-stagger">
      {business.services.map(service => {
        const img = serviceImages[service.name];
        const desc = serviceDescriptions[service.name] || '';
        return (
          <a
            href={service.slug}
            class="group relative bg-white border border-neutral-200 rounded-DEFAULT overflow-hidden hover:shadow-md hover:border-primary-300 transition-all reveal"
          >
            {/* Service image */}
            {img && (
              <div class="relative h-40 overflow-hidden">
                <Image
                  src={img}
                  alt={service.name}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  width={400}
                  height={160}
                  loading="lazy"
                />
                {service.tag && (
                  <span class={`absolute top-3 right-3 text-xs font-semibold px-2.5 py-1 rounded-full ${tagColors[service.tagStyle || 'blue'] || ''}`}>
                    {service.tag}
                  </span>
                )}
              </div>
            )}

            <div class="p-5">
              <h3 class="text-lg font-heading font-bold text-primary-900 mb-2">{service.name}</h3>
              <p class="text-sm text-neutral-600 leading-relaxed mb-3">{desc}</p>
              <span class="inline-flex items-center gap-1 text-sm text-primary-600 font-medium group-hover:gap-2 transition-all">
                En savoir plus
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
              </span>
            </div>
          </a>
        );
      })}
    </div>

    <!-- Verbatim -->
    <blockquote class="mt-16 max-w-2xl mx-auto text-center reveal">
      <p class="text-xl md:text-2xl font-heading text-primary-800 italic leading-relaxed">
        "Pas de surcoûts de structure. Vous payez l'expertise, pas les bureaux."
      </p>
      <cite class="block mt-3 text-sm text-neutral-500 not-italic">— Marc Muller</cite>
    </blockquote>
  </div>
</section>
