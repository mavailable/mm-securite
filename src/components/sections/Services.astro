---
/** Services — variante cards-icones : grille 2x3 avec SVG inline */
import { business } from '@data/business';

const serviceIcons: Record<string, string> = {
  'Alarme intrusion': '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/>',
  'Alarme incendie': '<path d="M12 12c2-2.96 0-7-1-8 0 3.038-1.773 4.741-3 6-1.226 1.26-2 3.24-2 5a6 6 0 1012 0c0-1.532-1.056-3.94-2-5-1.786 3-2.791 3-4 2z"/>',
  'Vidéosurveillance': '<path d="M23 7l-7 5 7 5V7z"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/>',
  "Contrôle d'accès": '<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/>',
  "Plans d'évacuation": '<path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>',
  'Mise en conformité ERP': '<path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>',
};

const tagColors: Record<string, string> = {
  blue: 'bg-primary-100 text-primary-700',
  red: 'bg-red-100 text-red-700',
};
---

<section id="services" class="py-16 md:py-24 bg-white">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center mb-12 reveal">
      <h2 class="text-2xl md:text-4xl font-heading font-bold text-primary-900 mb-3">
        Ce que j'installe et ce que je maintiens
      </h2>
      <p class="text-neutral-600 max-w-2xl mx-auto">
        Alarme, vidéo, incendie, contrôle d'accès — tout ce qu'il faut pour sécuriser votre commerce et passer la commission de sécurité.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto reveal-stagger">
      {business.services.map(service => (
        <a
          href={service.slug}
          class="group relative bg-white border border-neutral-200 rounded-DEFAULT p-6 hover:shadow-md hover:border-primary-300 transition-all reveal"
        >
          {service.tag && (
            <span class={`absolute top-4 right-4 text-xs font-semibold px-2.5 py-1 rounded-full ${tagColors[service.tagStyle || 'blue'] || ''}`}>
              {service.tag}
            </span>
          )}
          <div class="w-12 h-12 rounded-DEFAULT bg-primary-50 flex items-center justify-center mb-4 group-hover:bg-primary-100 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-primary-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={serviceIcons[service.name] || ''} />
          </div>
          <h3 class="text-lg font-heading font-bold text-primary-900 mb-2">{service.name}</h3>
          <p class="text-sm text-neutral-600 leading-relaxed">
            {/* Description from content collection - simplified for index */}
          </p>
          <span class="inline-flex items-center gap-1 text-sm text-primary-600 font-medium mt-3 group-hover:gap-2 transition-all">
            En savoir plus
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </span>
        </a>
      ))}
    </div>

    <!-- Verbatim between services and next section -->
    <blockquote class="mt-16 max-w-2xl mx-auto text-center reveal">
      <p class="text-xl md:text-2xl font-heading text-primary-800 italic leading-relaxed">
        "Pas de surcoûts de structure. Vous payez l'expertise, pas les bureaux."
      </p>
      <cite class="block mt-3 text-sm text-neutral-500 not-italic">— Marc Muller</cite>
    </blockquote>
  </div>
</section>
