---
/** Comment ça se passe — Timeline 5 étapes */
const steps = [
  { number: '1', title: 'Premier contact', desc: 'Appel, formulaire ou prise de RDV en ligne. Je vous écoute et je comprends votre besoin.' },
  { number: '2', title: 'Visite gratuite', desc: 'Je me déplace pour évaluer vos locaux. Aucun engagement, aucun frais.' },
  { number: '3', title: 'Devis sous 48h', desc: 'Devis détaillé, transparent, sans surprise. Vous savez exactement ce que vous payez.' },
  { number: '4', title: 'Installation', desc: 'Planifiée selon vos horaires. La plupart des installations sont terminées en une journée.' },
  { number: '5', title: 'Formation + suivi', desc: 'Je vous forme sur place. Maintenance annuelle proposée. Un SMS suffit si vous avez une question.' },
];
---

<section class="py-16 md:py-24 bg-white">
  <div class="max-w-4xl mx-auto px-4">
    <div class="text-center mb-12 reveal">
      <h2 class="text-2xl md:text-4xl font-heading font-bold text-primary-900 mb-3">
        Comment ça se passe
      </h2>
      <p class="text-neutral-600">Du premier appel à la mise en service, en 5 étapes simples.</p>
    </div>

    <div class="relative">
      <!-- Vertical line -->
      <div class="absolute left-6 md:left-1/2 top-0 bottom-0 w-0.5 bg-primary-100 -translate-x-1/2 hidden md:block"></div>
      <div class="absolute left-6 top-0 bottom-0 w-0.5 bg-primary-100 md:hidden"></div>

      <div class="space-y-8 reveal-stagger">
        {steps.map((step, i) => (
          <div class={`relative flex items-start gap-6 md:gap-12 reveal ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
            <!-- Number circle -->
            <div class="shrink-0 w-12 h-12 rounded-full bg-accent-500 text-white font-heading font-bold text-lg flex items-center justify-center z-10 relative">
              {step.number}
            </div>
            <!-- Content -->
            <div class={`flex-1 bg-neutral-50 border border-neutral-200 rounded-DEFAULT p-5 ${i % 2 === 0 ? 'md:mr-auto md:max-w-sm' : 'md:ml-auto md:max-w-sm'}`}>
              <h3 class="font-heading font-bold text-primary-900 mb-1">{step.title}</h3>
              <p class="text-sm text-neutral-600 leading-relaxed">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
