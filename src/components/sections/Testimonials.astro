---
/** Temoignages -- variante grille 3 colonnes, source CMS */
import { getCollection } from 'astro:content';

// Ordre EXPLICITE (alphabetique par slug) : getCollection() ne garantit aucun
// ordre, et il bougeait selon les dossiers presents sous src/content/ (constate
// en ajoutant le singleton `seo`). L'ordre fige ici est celui deja en ligne.
const entries = (await getCollection('testimonials')).sort((a, b) => a.id.localeCompare(b.id));
const testimonials = entries.map((e) => ({
  _slug: e.id,
  ...e.data,
  initial: e.data.author.charAt(0).toUpperCase(),
}));
---

<section class="py-16 md:py-24 bg-white">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-left mb-12 reveal">
      <h2 class="text-2xl md:text-4xl font-heading font-bold text-primary-900 mb-3">
        Ce que disent mes clients
      </h2>
      <p class="text-neutral-600">Les prenoms ont ete modifies par souci de confidentialite.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl reveal-stagger">
      {testimonials.map(t => (
        <article class="bg-neutral-50 border border-neutral-200 rounded-DEFAULT p-6 flex flex-col reveal" data-cms-field={`testimonials:${t._slug}`}>
          {/* Stars */}
          <div class="flex gap-0.5 mb-4">
            {Array.from({ length: t.rating }).map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-accent-400 fill-accent-400" viewBox="0 0 24 24">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            ))}
          </div>

          {/* Quote */}
          <blockquote class="text-neutral-700 leading-relaxed text-sm flex-1 mb-4" data-cms-field={`testimonials:${t._slug}.text`}>
            "{t.text}"
          </blockquote>

          {/* Author */}
          <div class="flex items-center gap-3 pt-4 border-t border-neutral-200">
            <div class="w-10 h-10 rounded-full bg-primary-100 text-primary-700 font-bold text-sm flex items-center justify-center shrink-0">
              {t.initial}
            </div>
            <div>
              <p class="font-semibold text-primary-900 text-sm" data-cms-field={`testimonials:${t._slug}.author`}>{t.author}</p>
              <p class="text-xs text-neutral-500" data-cms-field={`testimonials:${t._slug}.role`}>{t.role}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
    <div class="text-center mt-10">
      <a href="/devis-gratuit" class="inline-flex items-center justify-center bg-accent-600 hover:bg-accent-700 text-white font-semibold py-3 px-6 rounded-DEFAULT min-h-[44px] transition-colors">
        Rejoignez nos clients satisfaits
      </a>
    </div>
  </div>
</section>
