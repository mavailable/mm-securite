---
/** Témoignages — variante grille 3 colonnes */
const testimonials = [
  {
    author: 'Sophie L.',
    role: 'Boulangerie — Metz Centre',
    rating: 5,
    text: "Marc a installé notre système d'alarme et les caméras en une journée. Tout fonctionne parfaitement, l'application sur le téléphone est très pratique. Je recommande à tous les commerçants du quartier.",
    initial: 'S',
  },
  {
    author: 'Philippe D.',
    role: 'Restaurant — Thionville',
    rating: 5,
    text: "On avait la commission de sécurité en urgence. Marc a fait l'audit, installé la détection incendie et préparé tous les documents en 10 jours. Commission passée sans remarque.",
    initial: 'P',
  },
  {
    author: 'Nadia K.',
    role: 'Salon de coiffure — Nancy',
    rating: 5,
    text: "Très bon contact, Marc prend le temps d'expliquer le fonctionnement de chaque équipement. Le suivi après installation est top. Mon salon est maintenant bien protégé et je gère tout depuis mon téléphone.",
    initial: 'N',
  },
];
---

<section class="py-16 md:py-24 bg-white">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-left mb-12 reveal">
      <h2 class="text-2xl md:text-4xl font-heading font-bold text-primary-900 mb-3">
        Ce que disent mes clients
      </h2>
      <p class="text-neutral-600">Les prénoms ont été modifiés par souci de confidentialité.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl reveal-stagger">
      {testimonials.map(t => (
        <article class="bg-neutral-50 border border-neutral-200 rounded-DEFAULT p-6 flex flex-col reveal">
          <!-- Stars -->
          <div class="flex gap-0.5 mb-4">
            {Array.from({ length: t.rating }).map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-accent-400 fill-accent-400" viewBox="0 0 24 24">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <blockquote class="text-neutral-700 leading-relaxed text-sm flex-1 mb-4">
            "{t.text}"
          </blockquote>

          <!-- Author -->
          <div class="flex items-center gap-3 pt-4 border-t border-neutral-200">
            <div class="w-10 h-10 rounded-full bg-primary-100 text-primary-700 font-bold text-sm flex items-center justify-center shrink-0">
              {t.initial}
            </div>
            <div>
              <p class="font-semibold text-primary-900 text-sm">{t.author}</p>
              <p class="text-xs text-neutral-500">{t.role}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
    <div class="text-center mt-10">
      <a href="/devis-gratuit" class="inline-flex items-center justify-center bg-accent-600 hover:bg-accent-700 text-white font-semibold py-3 px-6 rounded-DEFAULT min-h-[44px] transition-colors">
        Rejoignez nos clients satisfaits
      </a>
    </div>
  </div>
</section>
