---
/**
 * FAQ — accordéon natif <details> + Schema.org FAQPage
 * Doctrine C1 : source unique de verite src/content/faq/*.json
 */
import { getCollection } from 'astro:content';
import { getFAQPageSchema } from '@data/schemas';

const faqEntries = (await getCollection('faq')).sort(
  (a, b) => (a.data.order ?? 0) - (b.data.order ?? 0)
);
const faqs = faqEntries.map((e) => ({ _slug: e.id, ...e.data }));

// Schema.org FAQPage centralise — doctrine C1
const faqSchema = await getFAQPageSchema();
---

<section id="faq" class="py-16 md:py-24 bg-neutral-50">
  <div class="max-w-3xl mx-auto px-4">
    <h2 class="text-2xl md:text-4xl font-heading font-bold text-primary-900 mb-8 reveal">
      Questions fréquentes sur la sécurité de votre commerce
    </h2>

    <div class="space-y-3 reveal-stagger">
      {faqs.map(faq => (
        <details class="group bg-white border border-neutral-200 rounded-DEFAULT overflow-hidden reveal" data-cms-field={`faq:${faq._slug}`}>
          <summary class="flex items-center justify-between cursor-pointer px-6 py-4 text-primary-900 font-medium hover:bg-primary-50 transition-colors min-h-[44px]">
            <span class="pr-4" data-cms-field={`faq:${faq._slug}.question`}>{faq.question}</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0 text-neutral-400 group-open:rotate-180 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="faq-answer px-6 pb-4 text-neutral-600 leading-relaxed text-sm" data-cms-field={`faq:${faq._slug}.answer`}>
            {faq.answer}
          </div>
        </details>
      ))}
    </div>

    <!-- Verbatim after FAQ -->
    <blockquote class="mt-12 text-center reveal">
      <p class="text-lg font-heading text-primary-800 italic">
        "Je connais les attentes des commissions. Zéro mauvaise surprise le jour J."
      </p>
      <cite class="text-sm text-neutral-500 not-italic mt-2 block">— Marc Muller</cite>
    </blockquote>
  </div>

  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
</section>
