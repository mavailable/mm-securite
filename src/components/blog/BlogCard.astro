---
interface Props {
  slug: string;
  title: string;
  description: string;
  date: Date;
  category: string;
}

const { slug, title, description, date, category } = Astro.props;

const categoryColors: Record<string, { bg: string; text: string; dot: string }> = {
  'Réglementation ERP': { bg: 'bg-primary-50', text: 'text-primary-700', dot: 'bg-primary-500' },
  'Protection & équipements': { bg: 'bg-accent-50', text: 'text-accent-700', dot: 'bg-accent-500' },
  'Commission de sécurité': { bg: 'bg-secondary-50', text: 'text-secondary-700', dot: 'bg-secondary-500' },
  'Sécurité par métier': { bg: 'bg-neutral-100', text: 'text-neutral-700', dot: 'bg-neutral-500' },
};

const colors = categoryColors[category] || categoryColors['Réglementation ERP'];
const formattedDate = date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
---

<article class="blog-article group bg-white border border-neutral-200 rounded-DEFAULT p-6 hover:border-primary-300 hover:shadow-md transition-all" data-category={category}>
  <div class="flex items-center gap-3 mb-3">
    <span class={`inline-flex items-center gap-1.5 text-xs font-medium px-2.5 py-1 rounded-full ${colors.bg} ${colors.text}`}>
      <span class={`w-1.5 h-1.5 rounded-full ${colors.dot}`}></span>
      {category}
    </span>
    <time class="text-xs text-neutral-400" datetime={date.toISOString()}>{formattedDate}</time>
  </div>
  <h3 class="font-heading font-semibold text-lg text-primary-900 mb-2 group-hover:text-primary-700 transition-colors">
    <a href={`/blog/${slug}`} class="after:absolute after:inset-0 relative">
      {title}
    </a>
  </h3>
  <p class="text-sm text-neutral-600 leading-relaxed line-clamp-3 mb-3">{description}</p>
  <span class="inline-flex items-center gap-1 text-sm text-primary-600 font-medium group-hover:gap-2 transition-all">
    Lire
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
  </span>
</article>
