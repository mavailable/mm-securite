---
interface Props {
  title: string;
  description: string;
  heroTitle: string;
  heroSubtitle: string;
  breadcrumbName: string;
  schemaService?: string;
  schemaDescription?: string;
}

const { title, description, heroTitle, heroSubtitle, breadcrumbName, schemaService, schemaDescription } = Astro.props;
const canonical = new URL(Astro.url.pathname, 'https://mm-securite.fr').href;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Marc Muller" />

    <meta name="geo.region" content="FR-GES" />
    <meta name="geo.placename" content="Metz" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="MM Sécurité" />
    <meta property="og:image" content="https://mm-securite.fr/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://mm-securite.fr/og-image.png" />

    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" /></noscript>

    <title>{title}</title>

    <!-- Cloudflare Web Analytics : injection automatique via Cloudflare Pages -->
    <meta name="theme-color" content="#0c2340" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    {schemaService && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Service",
        "name": schemaService,
        "description": schemaDescription || description,
        "provider": {
          "@type": "LocalBusiness",
          "name": "MM Sécurité - Marc Muller EI",
          "url": "https://mm-securite.fr",
          "telephone": "+33688766648",
          "address": { "@type": "PostalAddress", "addressLocality": "Metz", "postalCode": "57000", "addressRegion": "Grand Est", "addressCountry": "FR" }
        },
        "areaServed": [
          { "@type": "City", "name": "Metz" },
          { "@type": "City", "name": "Thionville" },
          { "@type": "City", "name": "Nancy" },
          { "@type": "AdministrativeArea", "name": "Grand Est" }
        ]
      })} />
    )}

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://mm-securite.fr" },
        { "@type": "ListItem", "position": 2, "name": breadcrumbName, "item": canonical }
      ]
    })} />
  </head>
  <body>
    <style>
      :root {
        --blue-600: #1e5ea6;
        --blue-700: #174d8a;
        --blue-900: #0c2340;
        --blue-50: #eef4fb;
        --gray-50: #f8f9fa;
        --gray-100: #f1f3f5;
        --gray-200: #e1e5e9;
        --gray-500: #6b7280;
        --gray-600: #4b5563;
        --gray-700: #374151;
        --gray-800: #1f2937;
        --gray-900: #111827;
        --white: #ffffff;
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: 'Inter', -apple-system, sans-serif;
        color: var(--gray-800);
        line-height: 1.7;
        background: var(--white);
      }

      /* Header */
      .sp-header {
        background: var(--gray-900);
        padding: 1rem 0;
      }
      .sp-header-inner {
        max-width: 1120px;
        margin: 0 auto;
        padding: 0 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .sp-header a {
        color: var(--white);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.95rem;
      }
      .sp-header .sp-nav {
        display: flex;
        align-items: center;
        gap: 1.5rem;
      }
      .sp-header .sp-nav a {
        color: rgba(255,255,255,0.7);
        font-weight: 400;
        font-size: 0.85rem;
        transition: color 0.2s;
      }
      .sp-header .sp-nav a:hover { color: var(--white); }
      .sp-header .sp-phone {
        color: var(--white);
        font-weight: 600;
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        gap: 0.3rem;
      }

      /* Hero */
      .sp-hero {
        background: linear-gradient(135deg, var(--gray-900) 0%, var(--blue-700) 100%);
        padding: 4rem 1.5rem 3rem;
        color: var(--white);
      }
      .sp-hero-inner {
        max-width: 800px;
        margin: 0 auto;
      }
      .sp-hero .breadcrumb {
        font-size: 0.8rem;
        color: rgba(255,255,255,0.6);
        margin-bottom: 1.5rem;
      }
      .sp-hero .breadcrumb a {
        color: rgba(255,255,255,0.7);
        text-decoration: none;
      }
      .sp-hero .breadcrumb a:hover { color: var(--white); }
      .sp-hero h1 {
        font-size: 2.2rem;
        font-weight: 800;
        line-height: 1.25;
        margin-bottom: 1rem;
      }
      .sp-hero p {
        font-size: 1.1rem;
        color: rgba(255,255,255,0.8);
        max-width: 640px;
        line-height: 1.7;
      }
      .sp-hero .sp-hero-cta {
        margin-top: 1.5rem;
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
      }
      .sp-hero .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.6rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.95rem;
        text-decoration: none;
        transition: all 0.3s ease;
        border: 2px solid transparent;
      }
      .sp-hero .btn-primary {
        background: var(--blue-600);
        color: var(--white);
        border-color: var(--blue-600);
      }
      .sp-hero .btn-primary:hover {
        background: var(--white);
        color: var(--blue-600);
        border-color: var(--white);
      }
      .sp-hero .btn-ghost {
        background: transparent;
        color: var(--white);
        border-color: rgba(255,255,255,0.3);
      }
      .sp-hero .btn-ghost:hover {
        background: var(--white);
        color: var(--gray-900);
        border-color: var(--white);
      }

      /* Content */
      .sp-content {
        max-width: 800px;
        margin: 0 auto;
        padding: 3rem 1.5rem 2rem;
      }
      .sp-content h2 {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--gray-900);
        margin: 2.5rem 0 1rem;
        line-height: 1.3;
      }
      .sp-content h3 {
        font-size: 1.2rem;
        font-weight: 600;
        color: var(--gray-800);
        margin: 2rem 0 0.75rem;
      }
      .sp-content p {
        margin-bottom: 1.25rem;
        color: var(--gray-700);
        font-size: 1.05rem;
      }
      .sp-content ul, .sp-content ol {
        margin: 0 0 1.25rem 1.5rem;
        color: var(--gray-700);
      }
      .sp-content li {
        margin-bottom: 0.4rem;
        font-size: 1.05rem;
      }
      .sp-content strong { color: var(--gray-900); }
      .sp-content a { color: var(--blue-600); text-decoration: underline; text-underline-offset: 2px; }

      /* Inline CTA */
      .sp-inline-cta {
        background: var(--blue-50);
        border: 1px solid #dbeafe;
        border-radius: 12px;
        padding: 1.5rem 2rem;
        margin: 2rem 0;
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
      }
      .sp-inline-cta p {
        flex: 1;
        margin: 0;
        font-weight: 500;
        min-width: 200px;
      }
      .sp-inline-cta .btn-sm {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: var(--blue-600);
        color: var(--white);
        padding: 0.6rem 1.2rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.9rem;
        text-decoration: none;
        transition: background 0.2s;
        white-space: nowrap;
      }
      .sp-inline-cta .btn-sm:hover { background: var(--blue-700); }

      /* CTA box at end */
      .sp-cta {
        background: linear-gradient(135deg, var(--blue-50) 0%, var(--gray-50) 100%);
        border: 1px solid var(--gray-200);
        border-radius: 12px;
        padding: 2rem;
        margin: 3rem 0 0;
        text-align: center;
      }
      .sp-cta h3 {
        margin: 0 0 0.5rem;
        color: var(--gray-900);
      }
      .sp-cta p {
        color: var(--gray-600);
        font-size: 0.95rem;
        margin-bottom: 1.25rem;
      }
      .sp-cta .btn {
        display: inline-block;
        background: var(--blue-600);
        color: var(--white);
        padding: 0.75rem 2rem;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.95rem;
        transition: background 0.2s;
      }
      .sp-cta .btn:hover { background: var(--blue-700); }

      /* Related articles */
      .sp-related {
        max-width: 800px;
        margin: 0 auto;
        padding: 0 1.5rem 4rem;
      }
      .sp-related h2 {
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--gray-900);
        margin-bottom: 1.25rem;
      }
      .sp-related-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 1rem;
      }
      .sp-related-card {
        background: var(--gray-50);
        border: 1px solid var(--gray-200);
        border-radius: 10px;
        padding: 1.25rem;
        text-decoration: none;
        color: inherit;
        transition: transform 0.2s, box-shadow 0.2s;
      }
      .sp-related-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 16px rgba(0,0,0,0.06);
      }
      .sp-related-card h3 {
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--gray-900);
        margin-bottom: 0.3rem;
      }
      .sp-related-card p {
        font-size: 0.82rem;
        color: var(--gray-600);
        margin: 0;
      }

      /* Footer */
      .sp-footer {
        background: var(--gray-900);
        color: rgba(255,255,255,0.6);
        text-align: center;
        padding: 2rem 1.5rem;
        font-size: 0.85rem;
      }
      .sp-footer a {
        color: rgba(255,255,255,0.8);
        text-decoration: none;
      }

      /* Focus visible for accessibility */
      a:focus-visible, button:focus-visible, input:focus-visible, select:focus-visible, textarea:focus-visible {
        outline: 2px solid var(--blue-600);
        outline-offset: 2px;
      }

      @media (max-width: 600px) {
        .sp-hero h1 { font-size: 1.6rem; }
        .sp-content { padding: 2rem 1.25rem 2rem; }
        .sp-header .sp-nav { gap: 0.75rem; }
        .sp-header .sp-phone .phone-text { display: none; }
      }
    </style>

    <header class="sp-header">
      <div class="sp-header-inner">
        <a href="/">MM Sécurité</a>
        <div class="sp-nav">
          <a href="/#services">Services</a>
          <a href="/blog">Blog</a>
          <a href="tel:+33688766648" class="sp-phone">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
            <span class="phone-text">06 88 76 66 48</span>
          </a>
          <a href="/devis-gratuit" style="background:var(--blue-600);color:#fff;padding:0.4rem 1rem;border-radius:6px;font-weight:600;">Devis gratuit</a>
        </div>
      </div>
    </header>

    <div class="sp-hero">
      <div class="sp-hero-inner">
        <div class="breadcrumb">
          <a href="/">Accueil</a> &rsaquo; {breadcrumbName}
        </div>
        <h1>{heroTitle}</h1>
        <p>{heroSubtitle}</p>
        <div class="sp-hero-cta">
          <a href="/devis-gratuit" class="btn btn-primary">Demander un devis gratuit</a>
          <a href="tel:+33688766648" class="btn btn-ghost">Appeler : 06 88 76 66 48</a>
        </div>
      </div>
    </div>

    <div class="sp-content">
      <slot />

      <div class="sp-cta">
        <h3>Besoin d'un devis pour votre commerce ?</h3>
        <p>Alarme, vidéosurveillance, mise en conformité ERP — contactez-moi pour un diagnostic gratuit.</p>
        <a href="/devis-gratuit" class="btn">Demander un devis gratuit</a>
      </div>
    </div>

    <slot name="related" />

    <footer class="sp-footer">
      <p>&copy; {new Date().getFullYear()} MM Sécurité — Marc Muller EI | <a href="/">Accueil</a> | <a href="/blog">Blog</a> | <a href="/mentions-legales">Mentions légales</a> | <a href="/politique-de-confidentialite">Confidentialité</a></p>
    </footer>
  </body>
</html>
