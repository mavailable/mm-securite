---
/**
 * Layout pour pages services et pages villes
 * Réutilise BaseLayout + Header + Footer + breadcrumbs
 */
import BaseLayout from './BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import MobileStickyCTA from '@components/layout/MobileStickyCTA.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro:assets';
import { business } from '@data/business';

interface Props {
  title: string;
  description: string;
  heroTitle: string;
  heroSubtitle: string;
  breadcrumbLabel: string;
  heroImage?: ImageMetadata;
}

const { title, description, heroTitle, heroSubtitle, breadcrumbLabel, heroImage } = Astro.props;
const siteUrl = business.siteUrl;
const currentPath = Astro.url.pathname;

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": breadcrumbLabel, "item": `${siteUrl}${currentPath}` },
  ],
});
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={breadcrumbSchema} />
  </Fragment>

  <Header slot="header" />

  {heroImage ? (
    <section class="relative text-white overflow-hidden min-h-[350px] md:min-h-[450px] flex items-end">
      <Image
        src={heroImage}
        alt={heroTitle}
        class="absolute inset-0 w-full h-full object-cover"
        widths={[640, 1024, 1536]}
        sizes="100vw"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-primary-950/90 via-primary-900/60 to-primary-900/30"></div>
      <div class="relative max-w-4xl mx-auto px-4 py-12 md:py-16 w-full">
        <nav class="text-sm text-white/90 mb-4" aria-label="Fil d'Ariane">
          <a href="/" class="hover:text-accent-400 transition-colors">Accueil</a>
          <span class="mx-2">/</span>
          <span>{breadcrumbLabel}</span>
        </nav>
        <h1 class="text-3xl md:text-5xl font-heading font-bold text-white mb-4">{heroTitle}</h1>
        <p class="text-lg text-white/90 max-w-2xl">{heroSubtitle}</p>
      </div>
    </section>
  ) : (
    <section class="bg-gradient-to-br from-primary-900 to-primary-950 text-white py-16 md:py-20">
      <div class="max-w-4xl mx-auto px-4">
        <nav class="text-sm text-white/90 mb-4" aria-label="Fil d'Ariane">
          <a href="/" class="hover:text-accent-400 transition-colors">Accueil</a>
          <span class="mx-2">/</span>
          <span>{breadcrumbLabel}</span>
        </nav>
        <h1 class="text-3xl md:text-5xl font-heading font-bold text-white mb-4">{heroTitle}</h1>
        <p class="text-lg text-white/90 max-w-2xl">{heroSubtitle}</p>
      </div>
    </section>
  )}

  <article class="py-16 md:py-24 bg-white">
    <div class="max-w-4xl mx-auto px-4 prose prose-neutral max-w-none">
      <slot />
    </div>
  </article>

  <section class="py-12 bg-accent-50 text-center">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-2xl font-heading font-bold text-primary-900 mb-4">Un projet ? Parlons-en.</h2>
      <p class="text-neutral-600 mb-6">Devis gratuit sous 48 heures, sans engagement.</p>
      <a href="/devis-gratuit" class="inline-flex items-center justify-center bg-accent-600 hover:bg-accent-700 text-white font-semibold py-3.5 px-8 rounded-DEFAULT min-h-[44px] transition-colors text-lg">
        Demander mon devis gratuit
      </a>
    </div>
  </section>

  <Footer slot="footer" />
  <MobileStickyCTA />
</BaseLayout>
