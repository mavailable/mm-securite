export const prerender = true;
---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import { business, legal } from '@data/business';
---

<BaseLayout
  title="Mentions légales · MM Sécurité"
  description="Mentions légales du site mm-securite.fr. Éditeur : Marc Muller EI, SIRET 505 045 450 00069, Metz."
>
  <Header slot="header" />

  <article class="py-16 md:py-24 bg-white">
    <div class="max-w-3xl mx-auto px-4 prose prose-neutral">
      <h1 class="text-3xl font-heading font-bold text-primary-900 mb-8">Mentions légales</h1>

      <section>
        <h2 class="text-xl font-heading font-bold text-primary-900 mt-8 mb-4">Éditeur du site</h2>
        <p>
          <strong>{business.legalName}</strong><br />
          Entreprise individuelle<br />
          SIRET : {legal.registrationNumber}<br />
          {business.address.city}, {business.address.postalCode} — {business.address.countryName}<br />
          Téléphone : <a href={`tel:${business.phone}`} class="text-primary-600 hover:underline">{business.phoneDisplay}</a><br />
          Email : <a href={`mailto:${business.email}`} class="text-primary-600 hover:underline">{business.email}</a>
        </p>
      </section>

      <section>
        <h2 class="text-xl font-heading font-bold text-primary-900 mt-8 mb-4">Directeur de la publication</h2>
        <p>{business.owner}, en qualité de dirigeant de {business.legalName}.</p>
      </section>

      <section>
        <h2 class="text-xl font-heading font-bold text-primary-900 mt-8 mb-4">Hébergement</h2>
        <p>
          Cloudflare, Inc.<br />
          101 Townsend St, San Francisco, CA 94107, États-Unis<br />
          Téléphone : +1 (650) 319-8930<br />
          Site : <a href="https://www.cloudflare.com" class="text-primary-600 hover:underline" target="_blank" rel="noopener">www.cloudflare.com</a>
        </p>
      </section>

      <section>
        <h2 class="text-xl font-heading font-bold text-primary-900 mt-8 mb-4">Propriété intellectuelle</h2>
        <p>
          L'ensemble du contenu de ce site (textes, images, graphismes, logo, icônes) est la propriété exclusive de {business.legalName}, sauf mention contraire. Toute reproduction, représentation, modification, publication ou adaptation de tout ou partie des éléments du site est interdite sans autorisation écrite préalable.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-heading font-bold text-primary-900 mt-8 mb-4">Données personnelles</h2>
        <p>
          Les informations relatives au traitement de vos données personnelles sont détaillées dans notre <a href="/politique-de-confidentialite" class="text-primary-600 hover:underline">politique de confidentialité</a>.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-heading font-bold text-primary-900 mt-8 mb-4">Cookies</h2>
        <p>
          Ce site ne dépose aucun cookie sur votre appareil. L'outil d'analyse d'audience utilisé (Umami) est respectueux de la vie privée et fonctionne sans cookies, conformément aux recommandations de la CNIL.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-heading font-bold text-primary-900 mt-8 mb-4">Responsabilité</h2>
        <p>
          {business.legalName} s'efforce de fournir des informations aussi précises que possible sur ce site. Toutefois, je ne saurais être tenu responsable des omissions, inexactitudes ou carences dans la mise à jour, qu'elles soient de mon fait ou du fait de tiers partenaires. Les informations sont fournies à titre indicatif et sont susceptibles d'évoluer.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-heading font-bold text-primary-900 mt-8 mb-4">Conception du site</h2>
        <p>
          Site conçu par <a href={business.credit.url} class="text-primary-600 hover:underline" target="_blank" rel="noopener">Marc M.</a> — Spécialiste sites web pour artisans et commerces.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-heading font-bold text-primary-900 mt-8 mb-4">Droit applicable</h2>
        <p>
          Le présent site et ses mentions légales sont régis par le droit français. En cas de litige, les tribunaux de Metz seront seuls compétents.
        </p>
      </section>
    </div>
  </article>

  <Footer slot="footer" />
</BaseLayout>
