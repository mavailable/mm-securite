export const prerender = true;
---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import { business } from '@data/business';
---

<BaseLayout
  title="Page introuvable — MM Sécurité"
  description="Cette page n'existe pas ou a été déplacée."
  noindex={true}
>
  <Header slot="header" />

  <section class="min-h-[60vh] flex items-center justify-center px-4 py-16">
    <div class="text-center max-w-lg">
      <h1 class="text-7xl font-bold text-primary-200 font-heading mb-2">404</h1>
      <h2 class="text-2xl font-bold text-primary-900 font-heading mb-4">Page introuvable</h2>
      <p class="text-neutral-600 mb-8">Cette page n'existe pas ou a été déplacée. Voici quelques liens utiles.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="bg-accent-600 hover:bg-accent-700 text-white font-semibold py-3 px-6 rounded-DEFAULT min-h-[44px] transition-colors">
          Retour à l'accueil
        </a>
        <a href="/devis-gratuit" class="border border-primary-300 text-primary-700 hover:bg-primary-50 font-semibold py-3 px-6 rounded-DEFAULT min-h-[44px] transition-colors">
          Demander un devis
        </a>
        <a href={`tel:${business.phone}`} class="border border-primary-300 text-primary-700 hover:bg-primary-50 font-semibold py-3 px-6 rounded-DEFAULT min-h-[44px] transition-colors">
          Appeler
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
