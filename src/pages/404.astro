---
import '../styles/global.css';
// Custom 404 page
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="description" content="Page introuvable — MM Sécurité" />
    <title>Page introuvable | MM Sécurité</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />    <!-- Cloudflare Web Analytics : injection automatique via Cloudflare Pages -->
    <meta name="theme-color" content="#0c2340" />
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: var(--font-body, 'Inter', -apple-system, sans-serif);
        color: var(--gray-800);
        background: var(--white, #fff);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      .header-404 {
        background: var(--gray-900);
        padding: 1rem 1.5rem;
      }
      .header-404 a {
        color: #fff;
        text-decoration: none;
        font-weight: 700;
        font-size: 1.1rem;
      }
      .content-404 {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 2rem;
      }
      .content-404 h1 {
        font-size: 6rem;
        font-weight: 800;
        color: var(--gray-200);
        line-height: 1;
        margin-bottom: 1rem;
      }
      .content-404 h2 {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--gray-900);
        margin-bottom: 0.75rem;
      }
      .content-404 p {
        color: var(--gray-500);
        font-size: 1.05rem;
        margin-bottom: 2rem;
        max-width: 440px;
        line-height: 1.6;
      }
      .links-404 {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        justify-content: center;
      }
      .btn-404 {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.7rem 1.4rem;
        border-radius: var(--radius-sm);
        font-weight: 600;
        font-size: 0.9rem;
        text-decoration: none;
        transition: var(--transition-fast);
      }
      .btn-primary-404 {
        background: var(--blue-600);
        color: #fff;
      }
      .btn-primary-404:hover { background: var(--blue-700); }
      .btn-ghost-404 {
        background: transparent;
        color: var(--blue-600);
        border: 1px solid var(--gray-300);
      }
      .btn-ghost-404:hover { background: var(--blue-50); }
      .footer-404 {
        background: var(--gray-900);
        color: rgba(255,255,255,0.9);
        text-align: center;
        padding: 1.5rem;
        font-size: 0.85rem;
      }
      .footer-404 a { color: rgba(255,255,255,0.9); text-decoration: none; }
    </style>
  </head>
  <body>
    <header class="header-404">
      <a href="/">MM Sécurité</a>
    </header>

    <main class="content-404">
      <div>
        <h1>404</h1>
        <h2>Page introuvable</h2>
        <p>La page que vous cherchez n'existe pas ou a été déplacée. Pas d'inquiétude, voici quelques liens utiles.</p>
        <div class="links-404">
          <a href="/" class="btn-404 btn-primary-404">Retour à l'accueil</a>
          <a href="/devis-gratuit" class="btn-404 btn-ghost-404">Demander un devis</a>
          <a href="/blog" class="btn-404 btn-ghost-404">Lire le blog</a>
          <a href="tel:+33688766648" class="btn-404 btn-ghost-404">Appeler</a>
        </div>
      </div>
    </main>

    <footer class="footer-404">
      <p>&copy; {new Date().getFullYear()} MM Sécurité — Marc Muller EI | <a href="/mentions-legales">Mentions légales</a> | <a href="/politique-de-confidentialite">Confidentialité</a></p>
    </footer>
  </body>
</html>
