---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import MobileStickyCTA from '@components/layout/MobileStickyCTA.astro';
import BlogCard from '@components/blog/BlogCard.astro';
import { getCollection } from 'astro:content';
import { marked } from 'marked';  // safety net transitoire Phase 8 (+2 semaines) — purge prevue 2026-04-28
import { business } from '@data/business';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro:assets';
import blogAlarmeConnectee from '@/assets/images/blog-alarme-connectee.jpg';
import blogCambriolage from '@/assets/images/blog-cambriolage.jpg';
import blogIncendieObligatoire from '@/assets/images/blog-incendie-obligatoire.jpg';
import blogVideoRgpd from '@/assets/images/blog-videosurveillance-rgpd.jpg';
import blogGenerique from '@/assets/images/blog-securite-generique.jpg';

const blogImages: Record<string, ImageMetadata> = {
  'alarme-connectee-smartphone-commerce': blogAlarmeConnectee,
  'cambriolage-commerce-que-faire': blogCambriolage,
  'detecteur-incendie-obligatoire-commerce': blogIncendieObligatoire,
  'videosurveillance-commerce-rgpd': blogVideoRgpd,
};

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
// Migration 2026-04-14 : content stocke en HTML only dans les JSON.
// Safety net detecteur MD-or-HTML garde 2 semaines (Phase 8 purge 2026-04-28).
const _body = post.data.content || '';
const htmlContent = _body.trimStart().startsWith('<') ? _body : marked(_body);
const wordCount = _body.replace(/<[^>]+>/g, ' ').split(/\s+/).filter(Boolean).length;
const readingTime = Math.ceil(wordCount / 200);
const formattedDate = new Date(post.data.date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });

const allPosts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const relatedPosts = allPosts.filter(p => p.id !== post.id).slice(0, 2);

const siteUrl = business.siteUrl;
const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": new Date(post.data.date).toISOString(),
  "author": { "@type": "Person", "name": business.owner },
  "publisher": { "@type": "Organization", "name": business.name, "url": siteUrl },
  "mainEntityOfPage": `${siteUrl}/blog/${post.id}`,
});

const categoryColors: Record<string, { bg: string; text: string; dot: string }> = {
  'Réglementation ERP': { bg: 'bg-primary-100', text: 'text-primary-200', dot: 'bg-primary-400' },
  'Protection & équipements': { bg: 'bg-accent-100', text: 'text-accent-200', dot: 'bg-accent-400' },
  'Commission de sécurité': { bg: 'bg-secondary-100', text: 'text-secondary-200', dot: 'bg-secondary-400' },
  'Sécurité par métier': { bg: 'bg-neutral-200', text: 'text-neutral-300', dot: 'bg-neutral-400' },
};
const colors = categoryColors[post.data.category] || categoryColors['Réglementation ERP'];

const coverImage = blogImages[post.id] || blogGenerique;
---

<BaseLayout
  title={`${post.data.title} · Blog MM Sécurité`}
  description={post.data.description}
  ogType="article"
>
  <Fragment slot="head">
    <meta property="article:published_time" content={new Date(post.data.date).toISOString()} />
    <meta property="article:author" content={business.owner} />
    <script type="application/ld+json" set:html={articleSchema} />
  </Fragment>

  <Header slot="header" />

  <!-- Article header -->
  <section class="relative text-white overflow-hidden min-h-[300px] md:min-h-[400px] flex items-end">
    <Image
      src={coverImage}
      alt={post.data.title}
      class="absolute inset-0 w-full h-full object-cover"
      widths={[640, 1024, 1536]}
      sizes="100vw"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-primary-950/90 via-primary-900/60 to-primary-900/30"></div>
    <div class="max-w-3xl mx-auto px-4 py-12 md:py-16 relative w-full">
      <nav class="text-sm text-white/90 mb-4" aria-label="Fil d'Ariane">
        <a href="/" class="hover:text-accent-400 transition-colors">Accueil</a>
        <span class="mx-2">/</span>
        <a href="/blog" class="hover:text-accent-400 transition-colors">Blog</a>
        <span class="mx-2">/</span>
        <span class="truncate max-w-[200px] inline-block align-bottom">{post.data.title}</span>
      </nav>
      <div class="flex items-center gap-3 mb-4">
        <span class="inline-flex items-center gap-1.5 text-xs font-medium px-2.5 py-1 rounded-full bg-white/10 text-white/90">
          {post.data.category}
        </span>
        <span class="text-xs text-white/90">{readingTime} min de lecture</span>
      </div>
      <h1 class="text-2xl md:text-4xl font-heading font-bold text-white leading-tight mb-4">{post.data.title}</h1>
      <div class="flex items-center gap-3 text-white/90 text-sm">
        <span class="font-medium">{business.owner}</span>
        <span>·</span>
        <time datetime={new Date(post.data.date).toISOString()}>{formattedDate}</time>
      </div>
    </div>
  </section>

  <!-- Article body -->
  <article class="py-16 md:py-24 bg-white">
    <div class="max-w-3xl mx-auto px-4">
      <div class="prose text-base md:text-lg" set:html={htmlContent} />

      <!-- Author card -->
      <div class="mt-16 pt-8 border-t border-neutral-200">
        <div class="flex items-center gap-4">
          <div class="w-14 h-14 rounded-full bg-primary-100 text-primary-700 flex items-center justify-center text-xl font-bold font-heading shrink-0">
            M
          </div>
          <div>
            <p class="font-heading font-bold text-primary-900">{business.owner}</p>
            <p class="text-sm text-neutral-600">{business.ownerRole} — {business.address.city}</p>
          </div>
        </div>
      </div>
    </div>
  </article>

  <!-- Related posts -->
  {relatedPosts.length > 0 && (
    <section class="py-12 bg-neutral-50">
      <div class="max-w-5xl mx-auto px-4">
        <h2 class="text-xl font-heading font-bold text-primary-900 mb-6">Articles liés</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {relatedPosts.map(p => (
            <BlogCard
              slug={p.id}
              title={p.data.title}
              description={p.data.description}
              date={new Date(p.data.date)}
              category={p.data.category}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="py-12 bg-accent-50 text-center">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-2xl font-heading font-bold text-primary-900 mb-4">Un projet de sécurité ?</h2>
      <p class="text-neutral-600 mb-6">Devis gratuit sous 48 heures, sans engagement.</p>
      <a href="/devis-gratuit" class="inline-flex items-center justify-center bg-accent-600 hover:bg-accent-700 text-white font-semibold py-3.5 px-8 rounded-DEFAULT min-h-[44px] transition-colors text-lg">
        Demander mon devis gratuit
      </a>
      <div class="flex flex-wrap justify-center gap-3 mt-6">
        <a href="/alarme-intrusion-commerce" class="text-sm text-primary-600 hover:text-primary-800 underline decoration-primary-200 hover:decoration-primary-400 transition-colors">Alarme intrusion</a>
        <span class="text-neutral-300">·</span>
        <a href="/videosurveillance-commerce" class="text-sm text-primary-600 hover:text-primary-800 underline decoration-primary-200 hover:decoration-primary-400 transition-colors">Vidéosurveillance</a>
        <span class="text-neutral-300">·</span>
        <a href="/alarme-incendie-erp" class="text-sm text-primary-600 hover:text-primary-800 underline decoration-primary-200 hover:decoration-primary-400 transition-colors">Alarme incendie</a>
        <span class="text-neutral-300">·</span>
        <a href="/mise-en-conformite-erp" class="text-sm text-primary-600 hover:text-primary-800 underline decoration-primary-200 hover:decoration-primary-400 transition-colors">Mise en conformité</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
  <MobileStickyCTA />
</BaseLayout>
