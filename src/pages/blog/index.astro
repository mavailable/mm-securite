---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Conseils sécurité pour commerces : alarme intrusion, vidéosurveillance, conformité ERP, détection incendie. Blog de MM Sécurité, technicien à Metz." />
    <meta name="author" content="Marc Muller" />

    <meta property="og:title" content="Blog Sécurité Commerces | MM Sécurité — Metz & Grand Est" />
    <meta property="og:description" content="Guides pratiques et conseils pour sécuriser votre commerce : alarme, vidéosurveillance, conformité ERP." />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:url" content="https://mm-securite.fr/blog" />
    <meta property="og:site_name" content="MM Sécurité" />
    <meta property="og:image" content="https://mm-securite.fr/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://mm-securite.fr/og-image.png" />

    <link rel="canonical" href="https://mm-securite.fr/blog" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <title>Blog Sécurité Commerces | MM Sécurité — Metz & Grand Est</title>

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Blog",
      "name": "Blog MM Sécurité",
      "description": "Conseils et guides pour la sécurité des commerces et ERP dans le Grand Est",
      "url": "https://mm-securite.fr/blog",
      "author": {
        "@type": "Person",
        "name": "Marc Muller"
      },
      "publisher": {
        "@type": "Organization",
        "name": "MM Sécurité",
        "url": "https://mm-securite.fr"
      }
    })} />
  </head>
  <body>
    <style>
      :root {
        --blue-600: #1e5ea6;
        --blue-700: #174d8a;
        --blue-50: #eef4fb;
        --gray-50: #f8f9fa;
        --gray-100: #f1f3f5;
        --gray-200: #e1e5e9;
        --gray-500: #6b7280;
        --gray-600: #4b5563;
        --gray-700: #374151;
        --gray-800: #1f2937;
        --gray-900: #111827;
        --white: #ffffff;
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: 'Inter', -apple-system, sans-serif;
        color: var(--gray-800);
        line-height: 1.6;
        background: var(--gray-50);
      }

      .blog-header {
        background: var(--gray-900);
        padding: 1rem 0;
      }
      .blog-header-inner {
        max-width: 900px;
        margin: 0 auto;
        padding: 0 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .blog-header a {
        color: var(--white);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.95rem;
      }
      .blog-header .back-link {
        color: rgba(255,255,255,0.7);
        font-weight: 400;
        font-size: 0.85rem;
        transition: color 0.2s;
      }
      .blog-header .back-link:hover { color: var(--white); }

      .blog-hero {
        background: linear-gradient(135deg, var(--gray-900) 0%, var(--blue-700) 100%);
        padding: 4rem 1.5rem;
        text-align: center;
        color: var(--white);
      }
      .blog-hero h1 {
        font-size: 2.2rem;
        font-weight: 800;
        margin-bottom: 0.75rem;
      }
      .blog-hero p {
        font-size: 1.05rem;
        color: rgba(255,255,255,0.75);
        max-width: 560px;
        margin: 0 auto;
      }

      .posts-grid {
        max-width: 900px;
        margin: 0 auto;
        padding: 3rem 1.5rem 4rem;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.5rem;
      }

      .post-card {
        background: var(--white);
        border-radius: 12px;
        border: 1px solid var(--gray-200);
        padding: 1.75rem;
        text-decoration: none;
        color: inherit;
        transition: transform 0.2s, box-shadow 0.2s;
        display: flex;
        flex-direction: column;
      }
      .post-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 30px rgba(0,0,0,0.08);
      }
      .post-card-date {
        font-size: 0.8rem;
        color: var(--gray-500);
        margin-bottom: 0.6rem;
      }
      .post-card h2 {
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--gray-900);
        line-height: 1.35;
        margin-bottom: 0.6rem;
      }
      .post-card p {
        font-size: 0.9rem;
        color: var(--gray-600);
        flex-grow: 1;
        margin-bottom: 1rem;
      }
      .post-card-tags {
        display: flex;
        gap: 0.35rem;
        flex-wrap: wrap;
      }
      .post-card-tags span {
        background: var(--blue-50);
        color: var(--blue-600);
        font-size: 0.72rem;
        font-weight: 500;
        padding: 0.15rem 0.5rem;
        border-radius: 10px;
      }
      .post-card-read {
        color: var(--blue-600);
        font-size: 0.85rem;
        font-weight: 600;
        margin-top: 0.75rem;
      }

      .blog-footer {
        background: var(--gray-900);
        color: rgba(255,255,255,0.6);
        text-align: center;
        padding: 2rem 1.5rem;
        font-size: 0.85rem;
      }
      .blog-footer a {
        color: rgba(255,255,255,0.8);
        text-decoration: none;
      }

      @media (max-width: 600px) {
        .blog-hero h1 { font-size: 1.6rem; }
        .posts-grid { grid-template-columns: 1fr; }
      }
    </style>

    <header class="blog-header">
      <div class="blog-header-inner">
        <a href="/">MM Sécurité</a>
        <a href="/" class="back-link">&larr; Retour au site</a>
      </div>
    </header>

    <div class="blog-hero">
      <h1>Blog Sécurité Commerces</h1>
      <p>Guides pratiques, obligations réglementaires et conseils pour protéger votre commerce dans le Grand Est.</p>
    </div>

    <div class="posts-grid">
      {posts.map((post) => (
        <a href={`/blog/${post.id}`} class="post-card">
          <div class="post-card-date">
            {post.data.date.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}
          </div>
          <h2>{post.data.title}</h2>
          <p>{post.data.description}</p>
          {post.data.tags.length > 0 && (
            <div class="post-card-tags">
              {post.data.tags.map((tag: string) => <span>{tag}</span>)}
            </div>
          )}
          <div class="post-card-read">Lire l'article &rarr;</div>
        </a>
      ))}
    </div>

    <footer class="blog-footer">
      <p>&copy; {new Date().getFullYear()} MM Sécurité — Marc Muller | <a href="/">Retour au site</a> | <a href="/mentions-legales">Mentions légales</a></p>
    </footer>
  </body>
</html>
