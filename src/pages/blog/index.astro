---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import MobileStickyCTA from '@components/layout/MobileStickyCTA.astro';
import BlogCard from '@components/blog/BlogCard.astro';
import BlogCardFeatured from '@components/blog/BlogCardFeatured.astro';
import { getCollection } from 'astro:content';
import { business } from '@data/business';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const [featuredPost, ...otherPosts] = allPosts;
const categories = [...new Set(allPosts.map(post => post.data.category))];

const siteUrl = business.siteUrl;
const blogSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Blog sécurité commerces — MM Sécurité",
  "url": `${siteUrl}/blog`,
  "description": "Conseils et obligations de sécurité pour commerces",
  "blogPost": allPosts.map(p => ({
    "@type": "BlogPosting",
    "headline": p.data.title,
    "url": `${siteUrl}/blog/${p.id}`,
    "datePublished": new Date(p.data.date).toISOString(),
  })),
});
---

<BaseLayout
  title="Blog sécurité commerces · MM Sécurité Metz"
  description="Conseils et obligations de sécurité pour commerces : normes ERP, RGPD vidéosurveillance, alarme intrusion, commission de sécurité."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={blogSchema} />
  </Fragment>

  <Header slot="header" />

  <section class="bg-gradient-to-br from-primary-900 to-primary-950 text-white py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4">
      <nav class="text-sm text-white/90 mb-4" aria-label="Fil d'Ariane">
        <a href="/" class="hover:text-accent-400 transition-colors">Accueil</a>
        <span class="mx-2">/</span>
        <span>Blog</span>
      </nav>
      <h1 class="text-3xl md:text-5xl font-heading font-bold text-white mb-4">Blog sécurité commerces</h1>
      <p class="text-lg text-white/90">Conseils, obligations et guides pratiques pour protéger votre commerce et passer la commission de sécurité.</p>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <!-- Category filters -->
      <div class="flex flex-wrap gap-2 mb-10" role="tablist" aria-label="Filtrer par catégorie">
        <button class="filter-btn active bg-primary-700 text-white shadow-sm text-sm font-medium px-4 py-2 rounded-full min-h-[44px] transition-colors" data-filter="all" role="tab" aria-selected="true">
          Tous les articles
        </button>
        {categories.map(cat => (
          <button class="filter-btn bg-white text-neutral-600 border border-neutral-200 hover:border-primary-300 text-sm font-medium px-4 py-2 rounded-full min-h-[44px] transition-colors" data-filter={cat} role="tab" aria-selected="false">
            {cat}
          </button>
        ))}
      </div>

      <!-- Featured post -->
      {featuredPost && (
        <div class="mb-8">
          <BlogCardFeatured
            slug={featuredPost.id}
            title={featuredPost.data.title}
            description={featuredPost.data.description}
            date={new Date(featuredPost.data.date)}
            category={featuredPost.data.category}
          />
        </div>
      )}

      <!-- Other posts grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {otherPosts.map(post => (
          <BlogCard
            slug={post.id}
            title={post.data.title}
            description={post.data.description}
            date={new Date(post.data.date)}
            category={post.data.category}
          />
        ))}
      </div>

      <!-- Empty state -->
      <div id="empty-state" class="hidden text-center py-12 text-neutral-500">
        Aucun article dans cette catégorie pour le moment.
      </div>
    </div>
  </section>

  <section class="py-12 bg-accent-50 text-center">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-2xl font-heading font-bold text-primary-900 mb-4">Un projet de sécurité ?</h2>
      <p class="text-neutral-600 mb-6">Devis gratuit sous 48 heures, sans engagement.</p>
      <a href="/devis-gratuit" class="inline-flex items-center justify-center bg-accent-600 hover:bg-accent-700 text-white font-semibold py-3.5 px-8 rounded-DEFAULT min-h-[44px] transition-colors text-lg">
        Demander mon devis gratuit
      </a>
    </div>
  </section>

  <Footer slot="footer" />
  <MobileStickyCTA />
</BaseLayout>

<script>
  const filterButtons = document.querySelectorAll('.filter-btn');
  const articles = document.querySelectorAll('.blog-article');
  const emptyState = document.getElementById('empty-state');

  filterButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = (btn as HTMLElement).dataset.filter;

      filterButtons.forEach(b => {
        b.classList.remove('active', 'bg-primary-700', 'text-white', 'shadow-sm');
        b.classList.add('bg-white', 'text-neutral-600', 'border', 'border-neutral-200');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.add('active', 'bg-primary-700', 'text-white', 'shadow-sm');
      btn.classList.remove('bg-white', 'text-neutral-600', 'border', 'border-neutral-200');
      btn.setAttribute('aria-selected', 'true');

      let visibleCount = 0;
      articles.forEach(article => {
        const el = article as HTMLElement;
        if (filter === 'all' || el.dataset.category === filter) {
          el.style.display = '';
          visibleCount++;
        } else {
          el.style.display = 'none';
        }
      });

      if (emptyState) {
        emptyState.classList.toggle('hidden', visibleCount > 0);
      }
    });
  });
</script>
