---
import '../styles/global.css';
// Page /merci — noindex, avec header + footer pour éviter l'impasse de navigation
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="description" content="Votre message a bien été envoyé. Nous vous recontactons sous 48 heures." />
    <title>Merci pour votre message | MM Sécurité</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Umami Analytics — privacy-first, no cookies, RGPD natif -->
    <script defer src="https://cloud.umami.is/script.js" data-website-id="13c56d5e-7dcb-4c57-a8fe-b46e9d359550" crossorigin="anonymous" is:inline></script>
    <meta name="theme-color" content="#0c2340" />
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: var(--font-body, 'Inter', -apple-system, sans-serif);
        color: var(--gray-800, #1f2937);
        background: #fff;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      .header-merci {
        background: var(--gray-900, #111827);
        padding: 1rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.75rem;
      }
      .header-merci .logo {
        color: #fff;
        text-decoration: none;
        font-weight: 700;
        font-size: 1.1rem;
      }
      .header-merci .phone {
        color: rgba(255,255,255,0.9);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
      }
      .header-merci .phone:hover { color: #fff; text-decoration: underline; }
      .content-merci {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 3rem 1.5rem;
      }
      .content-merci .inner {
        max-width: 520px;
      }
      .content-merci h1 {
        font-size: 2rem;
        color: #0c2340;
        margin-bottom: 1rem;
        line-height: 1.25;
      }
      .content-merci p {
        color: #4b5563;
        font-size: 1.05rem;
        margin-bottom: 2rem;
        line-height: 1.7;
      }
      .btn-primary-merci {
        display: inline-block;
        padding: 0.8rem 1.8rem;
        background: #1e5ea6;
        color: #fff;
        text-decoration: none;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.95rem;
        transition: background 0.2s;
      }
      .btn-primary-merci:hover { background: #1a4f8f; }
      .secondary-links {
        margin-top: 3rem;
        padding-top: 2rem;
        border-top: 1px solid #e5e7eb;
      }
      .secondary-links p {
        color: var(--gray-500);
        font-size: 0.9rem;
        margin-bottom: 1rem;
      }
      .secondary-links .links {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        justify-content: center;
      }
      .secondary-links a {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.5rem 1rem;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        color: #374151;
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 500;
        transition: border-color 0.2s, color 0.2s;
      }
      .secondary-links a:hover { border-color: #1e5ea6; color: #1e5ea6; }
      .footer-merci {
        background: var(--gray-900, #111827);
        color: rgba(255,255,255,0.9);
        text-align: center;
        padding: 1.5rem;
        font-size: 0.85rem;
      }
      .footer-merci a {
        color: rgba(255,255,255,0.9);
        text-decoration: none;
        margin: 0 0.4rem;
      }
      .footer-merci a:hover { text-decoration: underline; }
    </style>
  </head>
  <body>
    <header class="header-merci">
      <a href="/" class="logo">MM Sécurité</a>
      <a href="tel:+33688766648" class="phone">06 88 76 66 48</a>
    </header>

    <main class="content-merci">
      <div class="inner">
        <svg viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="1.5" width="64" height="64" style="margin-bottom: 1.5rem;" aria-hidden="true">
          <path d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <h1>Merci pour votre message&nbsp;!</h1>
        <p>
          Votre demande a bien été enregistrée. Je vous recontacte sous <strong>48 heures</strong> avec une proposition personnalisée.
        </p>
        <a href="/" class="btn-primary-merci">Retour à l'accueil</a>

        <div class="secondary-links">
          <p>En attendant, vous pouvez :</p>
          <div class="links">
            <a href="/blog">Lire le blog</a>
            <a href="/a-propos">En savoir plus sur MM Sécurité</a>
            <a href="tel:+33688766648">Appeler directement</a>
            <a href="https://g.page/r/CSqT00kK9RGOEBM/review" target="_blank" rel="noopener noreferrer">Laisser un avis Google</a>
          </div>
        </div>
      </div>
    </main>

    <footer class="footer-merci">
      <p>
        &copy; {new Date().getFullYear()} MM Sécurité — Marc Muller EI
        | <a href="/mentions-legales">Mentions légales</a>
        | <a href="/politique-de-confidentialite">Confidentialité</a>
      </p>
    </footer>
  </body>
</html>
