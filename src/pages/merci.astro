---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Merci | MM Sécurité"
  description="Votre message a bien été envoyé. Nous vous recontactons sous 48 heures."
>
  <section style="min-height: 100vh; display: flex; align-items: center; justify-content: center; text-align: center; padding: 2rem;">
    <div>
      <svg viewBox="0 0 24 24" fill="none" stroke="#1e5ea6" stroke-width="1.5" width="64" height="64" style="margin-bottom: 1.5rem;">
        <path d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <h1 style="font-size: 2rem; color: #0c2340; margin-bottom: 1rem;">Merci pour votre message !</h1>
      <p style="color: #4b5563; font-size: 1.1rem; margin-bottom: 2rem; max-width: 480px;">
        Votre demande a bien été enregistrée. Je vous recontacte sous <strong>48 heures</strong>.
      </p>
      <a href="/" style="display: inline-block; padding: 0.8rem 1.8rem; background: #1e5ea6; color: white; text-decoration: none; border-radius: 8px; font-weight: 600;">
        Retour à l'accueil
      </a>
    </div>
  </section>
</Layout>
