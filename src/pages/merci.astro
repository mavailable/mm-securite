---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import { business } from '@data/business';
---

<BaseLayout
  title="Merci pour votre message ! — MM Sécurité"
  description="Votre demande a bien été envoyée. Je vous recontacte sous 48 heures."
  noindex={true}
>
  <Header slot="header" />

  <section class="min-h-[60vh] flex items-center justify-center px-4 py-16">
    <div class="text-center max-w-lg">
      <div class="w-16 h-16 rounded-full bg-accent-100 text-accent-600 flex items-center justify-center mx-auto mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <h1 class="text-3xl font-bold text-primary-900 font-heading mb-4">Merci pour votre message !</h1>
      <p class="text-neutral-600 mb-8 leading-relaxed">
        Je vous recontacte sous 48 heures. En attendant, vous pouvez consulter mes articles sur la sécurité des commerces ou en savoir plus sur mon parcours.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="bg-primary-600 hover:bg-primary-700 text-white font-semibold py-3 px-6 rounded-DEFAULT min-h-[44px] transition-colors">
          Retour à l'accueil
        </a>
        <a href="/blog" class="border border-primary-300 text-primary-700 hover:bg-primary-50 font-semibold py-3 px-6 rounded-DEFAULT min-h-[44px] transition-colors">
          Lire le blog
        </a>
        <a href="/a-propos" class="border border-primary-300 text-primary-700 hover:bg-primary-50 font-semibold py-3 px-6 rounded-DEFAULT min-h-[44px] transition-colors">
          À propos
        </a>
      </div>
      <p class="mt-8 text-sm text-neutral-500">
        Besoin urgent ?
        <a href={`tel:${business.phone}`} class="text-primary-600 font-semibold hover:underline">{business.phoneDisplay}</a>
      </p>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
