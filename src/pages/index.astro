---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FAQ from '../components/FAQ.astro';
import Temoignages from '../components/Temoignages.astro';
import Zone from '../components/Zone.astro';
import Contact from '../components/Contact.astro';
import MobileStickyCTA from '../components/MobileStickyCTA.astro';
import { business } from '../data/business';
---

<Layout
  title="MM Sécurité | Alarme & Vidéosurveillance commerces Metz"
  description="Marc Muller, technicien en sécurité pour commerces à Metz. Alarme intrusion, incendie, vidéosurveillance, contrôle d'accès et mise en conformité ERP. Devis gratuit sous 48h."
>

  <Header />

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="container hero-layout">
      <div class="hero-inner">
        <div class="hero-badge">Technicien indépendant — Metz & Grand Est</div>
        <h1>
          Protégez votre<br />
          <span class="hero-gradient">commerce</span><br />
          en toute sérénité.
        </h1>
        <p class="hero-sub">
          Alarme, vidéosurveillance, détection incendie, contrôle d'accès — un seul interlocuteur pour <strong>sécuriser votre établissement</strong> et passer sereinement la commission de sécurité.
        </p>
        <div class="hero-cta">
          <a href="/devis-gratuit" class="btn btn-primary btn-glow">
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
            Demander un devis gratuit
          </a>
          <a href="#services" class="btn btn-ghost">Voir mes services</a>
        </div>
        <div class="hero-stats">
          <div class="stat">
            <span class="stat-num">48h</span>
            <span class="stat-label">Devis envoyé</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-num">50+</span>
            <span class="stat-label">Commerces protégés</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-num">1</span>
            <span class="stat-label">Interlocuteur unique</span>
          </div>
        </div>
      </div>

      <!-- HERO VISUAL -->
      <div class="hero-visual">
        <div class="hero-dashboard">
          <!-- Main dashboard card -->
          <div class="dash-main">
            <div class="dash-header">
              <div class="dash-dot green"></div>
              <span class="dash-title">Système actif</span>
              <span class="dash-badge-ok">En ligne</span>
            </div>
            <!-- Central shield -->
            <div class="dash-shield-wrap">
              <svg class="dash-shield" viewBox="0 0 120 140" fill="none">
                <defs>
                  <linearGradient id="sg" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0%" stop-color="#1e5ea6"/>
                    <stop offset="100%" stop-color="#4a9bdf"/>
                  </linearGradient>
                </defs>
                <path d="M60 8 L110 30 L110 72 C110 104 85 128 60 138 C35 128 10 104 10 72 L10 30 Z" fill="url(#sg)"/>
                <path d="M60 18 L102 37 L102 72 C102 99 80 120 60 129 C40 120 18 99 18 72 L18 37 Z" fill="rgba(255,255,255,0.12)"/>
                <path d="M45 70 L55 80 L78 55" stroke="white" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round" class="shield-check"/>
              </svg>
            </div>
            <!-- Status indicators -->
            <div class="dash-statuses">
              <div class="dash-status-line">
                <div class="dash-status-dot dot-green"></div>
                <span>Alarme</span>
                <span class="status-ok">Actif</span>
              </div>
              <div class="dash-status-line">
                <div class="dash-status-dot dot-green"></div>
                <span>Détection</span>
                <span class="status-ok">Actif</span>
              </div>
              <div class="dash-status-line">
                <div class="dash-status-dot dot-green"></div>
                <span>Surveillance</span>
                <span class="status-ok">Actif</span>
              </div>
            </div>
          </div>

          <!-- Floating card -->
          <div class="dash-float dash-float-1">
            <div class="dash-float-icon green-bg">
              <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" width="16" height="16"><path d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <span class="dash-float-value">Tout opérationnel</span>
          </div>

          <div class="dash-float dash-float-2">
            <div class="dash-float-icon blue-bg">
              <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="#1e5ea6" stroke-width="2" width="16" height="16"><path d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
            </div>
            <span class="dash-float-value">Conforme</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- BANDEAU REASSURANCE -->
  <section class="reassurance">
    <div class="container reassurance-inner">
      <div class="reassurance-item">
        <div class="reassurance-icon">
          <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
        </div>
        <div class="reassurance-text">
          <strong>Certifié NF</strong>
          <span>Matériel aux normes</span>
        </div>
      </div>
      <div class="reassurance-divider"></div>
      <div class="reassurance-item">
        <div class="reassurance-icon">
          <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <div class="reassurance-text">
          <strong>Conforme</strong>
          <span>RGPD & ERP</span>
        </div>
      </div>
      <div class="reassurance-divider"></div>
      <div class="reassurance-item">
        <div class="reassurance-icon icon-accent">
          <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>
        </div>
        <div class="reassurance-text">
          <strong>Rapide</strong>
          <span>Intervention express</span>
        </div>
      </div>
      <div class="reassurance-divider"></div>
      <div class="reassurance-item">
        <div class="reassurance-icon">
          <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
        </div>
        <div class="reassurance-text">
          <strong>Local</strong>
          <span>Basé à Metz</span>
        </div>
      </div>
      <div class="reassurance-divider"></div>
      <div class="reassurance-item">
        <div class="reassurance-icon">
          <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M11.35 3.836c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m8.9-4.414c.376.023.75.05 1.124.08 1.131.094 1.976 1.057 1.976 2.192V16.5A2.25 2.25 0 0118 18.75h-2.25m-7.5-10.5H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V18.75m-7.5-10.5h6.375c.621 0 1.125.504 1.125 1.125v9.375m-8.25-3l1.5 1.5 3-3.75"/></svg>
        </div>
        <div class="reassurance-text">
          <strong>Clé en main</strong>
          <span>Conformité incluse</span>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="services" id="services">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Services</span>
        <h2>Tout ce qu'il faut pour<br /><strong>sécuriser votre commerce</strong></h2>
        <p class="section-intro">De l'alarme intrusion à la mise en conformité incendie, je m'occupe de tout. Vous, concentrez-vous sur vos clients.</p>
      </div>

      <div class="services-grid">

        <a href="/alarme-intrusion-commerce" class="service-card" data-accent="blue" style="text-decoration:none;color:inherit;">
          <div class="service-icon">
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28"><path d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z"/></svg>
          </div>
          <div class="service-content">
            <h3>Alarme intrusion</h3>
            <p>Protégez votre boutique contre les cambriolages. Détection volumétrique, sirène, alerte sur smartphone, levée de doute vidéo. Centrales certifiées NF&nbsp;A2P.</p>
          </div>
          <span class="service-tag">Le plus demandé</span>
        </a>

        <a href="/alarme-incendie-erp" class="service-card" data-accent="red" style="text-decoration:none;color:inherit;">
          <div class="service-icon icon-red">
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28"><path d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z"/><path d="M12 18a3.75 3.75 0 00.495-7.467 5.99 5.99 0 00-1.925 3.546 5.974 5.974 0 01-2.133-1.001A3.75 3.75 0 0012 18z"/></svg>
          </div>
          <div class="service-content">
            <h3>Alarme incendie</h3>
            <p>Détection incendie conforme aux obligations ERP. Détecteurs, déclencheurs manuels, centrale SSI, vérification annuelle et tenue du registre de sécurité.</p>
          </div>
          <span class="service-tag tag-red">Obligatoire ERP</span>
        </a>

        <a href="/videosurveillance-commerce" class="service-card" style="text-decoration:none;color:inherit;">
          <div class="service-icon">
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28"><path d="M15.75 10.5l4.72-4.72a.75.75 0 011.28.53v11.38a.75.75 0 01-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 002.25-2.25v-9a2.25 2.25 0 00-2.25-2.25h-9A2.25 2.25 0 002.25 7.5v9a2.25 2.25 0 002.25 2.25z"/></svg>
          </div>
          <div class="service-content">
            <h3>Vidéosurveillance</h3>
            <p>Caméras IP haute définition, vision nocturne, accès en direct sur votre téléphone. Installation conforme RGPD avec affichage légal et déclaration préfecture.</p>
          </div>
        </a>

        <a href="/controle-acces-commerce" class="service-card" style="text-decoration:none;color:inherit;">
          <div class="service-icon">
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28"><path d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/></svg>
          </div>
          <div class="service-content">
            <h3>Contrôle d'accès</h3>
            <p>Badges, digicodes, lecteurs biométriques. Gérez qui entre et quand — idéal pour les réserves, bureaux ou zones à accès restreint.</p>
          </div>
        </a>

        <a href="/plan-evacuation-erp" class="service-card" style="text-decoration:none;color:inherit;">
          <div class="service-icon">
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28"><path d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z"/></svg>
          </div>
          <div class="service-content">
            <h3>Plans d'évacuation</h3>
            <p>Plans conformes NF&nbsp;X&nbsp;08-070, balisage de sécurité, signalétique. Indispensable pour passer la commission de sécurité en toute tranquillité.</p>
          </div>
        </a>

        <article class="service-card card-pro">
          <div class="service-icon icon-dark">
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28"><path d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0M12 12.75h.008v.008H12v-.008z"/></svg>
          </div>
          <div class="service-content">
            <h3>Sous-traitance pro</h3>
            <p>Installateurs, intégrateurs : je réalise vos chantiers sécurité en sous-traitance sur Metz et le Grand Est. Qualité, réactivité, flexibilité.</p>
          </div>
          <span class="service-tag tag-dark">B2B</span>
        </article>

      </div>
    </div>
  </section>

  <!-- COMMERCES / ERP -->
  <section class="commerces" id="commerces">
    <div class="commerces-glow commerces-glow-1"></div>
    <div class="commerces-glow commerces-glow-2"></div>
    <div class="container">
      <div class="commerces-header">
        <span class="section-tag tag-light">Spécialisation</span>
        <h2>Pensé pour les<br /><strong>petits commerces</strong></h2>
        <p class="commerces-subtitle">
          Votre boulangerie, restaurant ou cabinet médical doit respecter les mêmes normes que les grandes enseignes — mais avec un budget adapté. C'est exactement pour ça que MM&nbsp;Sécurité existe.
        </p>
      </div>

      <div class="commerces-benefits-grid">
        <div class="benefit-card">
          <div class="benefit-icon-wrap">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><path d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <strong>Tarifs adaptés</strong>
          <p>Pas de surcoûts de structure. Vous payez l'expertise, pas les bureaux.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-icon-wrap">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><path d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
          </div>
          <strong>Interlocuteur unique</strong>
          <p>Du devis à la maintenance, vous parlez toujours à la même personne.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-icon-wrap">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><path d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
          </div>
          <strong>Commission de sécurité</strong>
          <p>Je connais les attentes des commissions. Zéro mauvaise surprise le jour J.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-icon-wrap">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><path d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>
          </div>
          <strong>Réactif</strong>
          <p>Pas de planning de grand groupe. J'interviens vite, je m'adapte à vos horaires.</p>
        </div>
      </div>

      <div class="commerces-types-section">
        <h3 class="types-title">Établissements accompagnés</h3>
        <div class="type-pills">
          <a href="/securite-commerce-metz" class="type-pill">
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18"><path d="M13.5 21v-7.5a.75.75 0 01.75-.75h3a.75.75 0 01.75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349m-16.5 11.65V9.35m0 0a3.001 3.001 0 003.75-.615A2.993 2.993 0 009.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 002.25 1.016c.896 0 1.7-.393 2.25-1.016a3.001 3.001 0 003.75.614m-16.5 0a3.004 3.004 0 01-.621-4.72L4.318 3.44A1.5 1.5 0 015.378 3h13.243a1.5 1.5 0 011.06.44l1.19 1.189a3 3 0 01-.621 4.72m-13.5 8.65h3.75a.75.75 0 00.75-.75V13.5a.75.75 0 00-.75-.75H6.75a.75.75 0 00-.75.75v3.15c0 .415.336.75.75.75z"/></svg>
            Boulangeries
          </a>
          <a href="/securite-commerce-metz" class="type-pill">
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18"><path d="M12 8.25v-1.5m0 1.5c-1.355 0-2.697.056-4.024.166C6.845 8.51 6 9.473 6 10.608v2.513m6-4.871c1.355 0 2.697.056 4.024.166C17.155 8.51 18 9.473 18 10.608v2.513M15 8.25v-1.5m-6 1.5v-1.5m12 9.75l-1.5.75a3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0L3 16.5m15-3.379a48.474 48.474 0 00-6-.371c-2.032 0-4.034.126-6 .371m12 0c.39.049.777.102 1.163.16 1.07.16 1.837 1.094 1.837 2.175v5.169c0 .621-.504 1.125-1.125 1.125H4.125A1.125 1.125 0 013 20.625v-5.17c0-1.08.768-2.014 1.837-2.174A47.78 47.78 0 016 13.12M12.265 3.11a.375.375 0 11-.53 0L12 2.845l.265.265z"/></svg>
            Restaurants
          </a>
          <a href="/securite-commerce-metz" class="type-pill">
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18"><path d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>
            Salons de coiffure
          </a>
          <a href="/securite-commerce-metz" class="type-pill">
