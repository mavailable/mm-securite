---
/**
 * Page d'accueil — MM Sécurité V2
 * Layout: hero-dynamique + services-cards-icones + about-asymétrique + temoignages-grille
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import MobileStickyCTA from '@components/layout/MobileStickyCTA.astro';
import Hero from '@components/sections/Hero.astro';
import Reassurance from '@components/sections/Reassurance.astro';
import Services from '@components/sections/Services.astro';
import WhyMe from '@components/sections/WhyMe.astro';
import Testimonials from '@components/sections/Testimonials.astro';
import Zone from '@components/sections/Zone.astro';
import FAQ from '@components/sections/FAQ.astro';
import Process from '@components/sections/Process.astro';
import Contact from '@components/sections/Contact.astro';
import SchemaOrg from '@components/SchemaOrg.astro';
import { business } from '@data/business';
import { getHero } from '@data/content';

const hero = getHero();
---

<BaseLayout
  title={business.seo.defaultTitle}
  description={business.seo.defaultDescription}
>
  <SchemaOrg slot="head" />
  <Header slot="header" />

  <Hero
    title={hero.title}
    subtitle={hero.subtitle}
    ctaPrimary={hero.ctaPrimary}
    ctaPrimaryUrl={hero.ctaPrimaryUrl}
    ctaSecondary={hero.ctaSecondary}
    ctaSecondaryUrl={hero.ctaSecondaryUrl}
    stats={[
      { value: hero.stat1Value, label: hero.stat1Label },
      { value: hero.stat2Value, label: hero.stat2Label },
      { value: hero.stat3Value, label: hero.stat3Label },
    ]}
  />

  <Reassurance />
  <Services />
  <WhyMe />
  <Testimonials />
  <Process />
  <Zone />
  <FAQ />
  <Contact />

  <Footer slot="footer" />
  <MobileStickyCTA />
</BaseLayout>
