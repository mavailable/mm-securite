---
/**
 * Page d'accueil — MM Sécurité V2
 * Layout: hero-dynamique + services-cards-icones + about-asymétrique + temoignages-grille
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import MobileStickyCTA from '@components/layout/MobileStickyCTA.astro';
import Hero from '@components/sections/Hero.astro';
import Reassurance from '@components/sections/Reassurance.astro';
import Services from '@components/sections/Services.astro';
import WhyMe from '@components/sections/WhyMe.astro';
import Testimonials from '@components/sections/Testimonials.astro';
import Zone from '@components/sections/Zone.astro';
import FAQ from '@components/sections/FAQ.astro';
import Contact from '@components/sections/Contact.astro';
import SchemaOrg from '@components/SchemaOrg.astro';
import { business } from '@data/business';
---

<BaseLayout
  title={business.seo.defaultTitle}
  description={business.seo.defaultDescription}
>
  <SchemaOrg slot="head" />
  <Header slot="header" />

  <Hero
    title="Sécurité électronique pour commerces — Metz & Grand Est"
    subtitle="Technicien indépendant en alarme, vidéosurveillance, incendie et contrôle d'accès. J'installe, je maintiens, je mets en conformité. Un seul interlocuteur du devis à la maintenance."
    ctaPrimary="Demander mon devis gratuit"
    ctaPrimaryUrl="/devis-gratuit"
    ctaSecondary="Prendre rendez-vous"
    ctaSecondaryUrl="https://cal.com/marc-muller/30min"
    stats={[
      { value: '48h', label: 'Devis envoyé' },
      { value: '50+', label: 'Commerces protégés' },
      { value: '1', label: 'Interlocuteur unique' },
    ]}
  />

  <Reassurance />
  <Services />
  <WhyMe />
  <Testimonials />
  <Zone />
  <FAQ />
  <Contact />

  <Footer slot="footer" />
  <MobileStickyCTA />
</BaseLayout>
