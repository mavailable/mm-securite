const description = 'Protégez votre commerce à Metz avec nos solutions d\'alarme, vidéosurveillance et mise en conformité ERP. Intervention rapide, technician local.';
const heroTitle = 'Sécurité pour commerces à Metz';
const heroSubtitle = 'Alarme, vidéosurveillance et conformité ERP pour boutiques, restaurants et commerces du centre-ville de Metz';
const breadcrumbName = 'Sécurité Metz';
const schemaService = 'Sécurité pour commerces à Metz';
---

<ServicePage
  title={title}
