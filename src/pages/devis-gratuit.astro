---
import '../styles/global.css';
// No layout - this is a standalone page
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Demandez votre devis gratuit pour la sécurité de votre commerce. Alarme, vidéosurveillance, détection incendie. Réponse personnalisée sous 48 heures, sans engagement." />
    <meta name="author" content="Marc Muller" />

    <meta name="geo.region" content="FR-GES" />
    <meta name="geo.placename" content="Metz" />

    <meta property="og:title" content="Devis gratuit — MM Sécurité | Alarme & Vidéosurveillance Metz" />
    <meta property="og:description" content="Demandez votre devis gratuit pour sécuriser votre commerce. Réponse sous 48 heures, sans engagement." />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:url" content="https://mm-securite.fr/devis-gratuit" />
    <meta property="og:site_name" content="MM Sécurité" />
    <meta property="og:image" content="https://mm-securite.fr/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Devis gratuit — MM Sécurité" />
    <meta name="twitter:description" content="Demandez votre devis gratuit pour sécuriser votre commerce." />
    <meta name="twitter:image" content="https://mm-securite.fr/og-image.png" />

    <link rel="canonical" href="https://mm-securite.fr/devis-gratuit" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Devis gratuit — MM Sécurité | Alarme & Vidéosurveillance Metz</title>

    <!-- Cloudflare Web Analytics : injection automatique via Cloudflare Pages -->
    <meta name="theme-color" content="#0c2340" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <style>
      :root {
        --blue-600: #1e5ea6;
        --blue-700: #174d8a;
        --blue-900: #0c2340;
        --blue-50: #eef4fb;
        --gray-50: #f8f9fa;
        --gray-100: #f1f3f5;
        --gray-200: #e1e5e9;
        --gray-500: #6b7280;
        --gray-600: #4b5563;
        --gray-700: #374151;
        --gray-800: #1f2937;
        --gray-900: #111827;
        --white: #ffffff;
        --green: #22c55e;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: 'Inter', -apple-system, sans-serif;
        color: var(--gray-800);
        line-height: 1.6;
        background: var(--white);
      }

      /* Header */
      .dg-header {
        background: var(--gray-900);
        padding: 1rem 0;
        border-bottom: 1px solid rgba(255,255,255,0.05);
      }

      .dg-header-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .dg-logo {
        color: var(--white);
        text-decoration: none;
        font-weight: 700;
        font-size: 1.1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .dg-logo svg {
        width: 24px;
        height: 24px;
      }

      .dg-phone {
        color: var(--white);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        transition: opacity 0.2s;
      }

      .dg-phone:hover {
        opacity: 0.8;
      }

      .dg-phone svg {
        width: 16px;
        height: 16px;
      }

      /* Hero */
      .dg-hero {
        background: linear-gradient(135deg, var(--gray-900) 0%, var(--blue-700) 100%);
        padding: 3.5rem 1.5rem;
        color: var(--white);
        text-align: center;
      }

      .dg-hero h1 {
        font-size: 2rem;
        font-weight: 800;
        line-height: 1.2;
        margin-bottom: 0.75rem;
        max-width: 700px;
        margin-left: auto;
        margin-right: auto;
      }

      .dg-hero p {
        font-size: 1.05rem;
        color: rgba(255,255,255,0.9);
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
      }

      /* Trust strip */
      .dg-trust {
        background: var(--blue-50);
        padding: 1.5rem;
        border-bottom: 1px solid #dbeafe;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 2rem;
        text-align: center;
      }

      .dg-trust-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.4rem;
      }

      .dg-trust-item strong {
        font-size: 0.95rem;
        color: var(--gray-900);
        font-weight: 600;
      }

      .dg-trust-item span {
        font-size: 0.85rem;
        color: var(--gray-600);
      }

      /* Main content */
      .dg-container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 3rem 1.5rem;
      }

      .dg-layout {
        display: grid;
        grid-template-columns: 1fr 320px;
        gap: 3rem;
      }

      /* Form */
      .dg-form-section h2 {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--gray-900);
        margin-bottom: 1.5rem;
      }

      .dg-form {
        background: var(--white);
        border: 1px solid var(--gray-200);
        border-radius: 12px;
        padding: 2rem;
      }

      .form-group {
        margin-bottom: 1.5rem;
      }

      .form-group label {
        display: block;
        font-size: 0.95rem;
        font-weight: 500;
        color: var(--gray-900);
        margin-bottom: 0.5rem;
      }

      .form-group input,
      .form-group select,
      .form-group textarea {
        width: 100%;
        padding: 0.75rem 0.875rem;
        border: 1px solid var(--gray-200);
        border-radius: 8px;
        font-family: 'Inter', sans-serif;
        font-size: 0.95rem;
        color: var(--gray-800);
        transition: border-color 0.2s;
      }

      .form-group input:focus,
      .form-group select:focus,
      .form-group textarea:focus {
        outline: none;
        border-color: var(--blue-600);
        box-shadow: 0 0 0 3px rgba(30, 94, 166, 0.1);
      }

      .form-group textarea {
        resize: vertical;
        min-height: 120px;
      }

      .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
      }

      .form-note {
        font-size: 0.85rem;
        color: var(--gray-600);
        margin-top: 1rem;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.95rem;
        cursor: pointer;
        transition: all 0.2s;
        text-decoration: none;
        font-family: 'Inter', sans-serif;
      }

      .btn-primary {
        background: var(--blue-600);
        color: var(--white);
        width: 100%;
        justify-content: center;
        font-size: 1rem;
        padding: 0.875rem 1.5rem;
      }

      .btn-primary:hover:not(:disabled) {
        background: var(--blue-700);
      }

      .btn-primary:disabled {
        opacity: 0.7;
        cursor: not-allowed;
      }

      .btn svg {
        width: 18px;
        height: 18px;
      }

      /* Form success */
      .form-success {
        display: none;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1.5rem;
        padding: 3rem 2rem;
        text-align: center;
      }

      .success-icon {
        width: 60px;
        height: 60px;
        background: var(--blue-50);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .success-icon svg {
        width: 32px;
        height: 32px;
        stroke: var(--green);
      }

      .form-success h3 {
        font-size: 1.5rem;
        color: var(--gray-900);
        margin: 0;
      }

      .form-success p {
        color: var(--gray-600);
        margin: 0;
        font-size: 1rem;
      }

      .btn-ghost {
        background: transparent;
        color: var(--blue-600);
        border: 2px solid var(--blue-600);
      }

      .btn-ghost:hover {
        background: var(--blue-50);
      }

      /* Sidebar */
      .dg-sidebar {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }

      .sidebar-card {
        background: var(--gray-50);
        border: 1px solid var(--gray-200);
        border-radius: 12px;
        padding: 1.5rem;
      }

      .sidebar-card h3 {
        font-size: 1rem;
        font-weight: 700;
        color: var(--gray-900);
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .sidebar-card svg {
        width: 20px;
        height: 20px;
        color: var(--blue-600);
        flex-shrink: 0;
      }

      .contact-info {
        font-size: 0.9rem;
        color: var(--gray-700);
        line-height: 1.8;
      }

      .contact-info strong {
        color: var(--gray-900);
        display: block;
        margin-bottom: 0.3rem;
      }

      .contact-info a {
        color: var(--blue-600);
        text-decoration: none;
        font-weight: 500;
      }

      .contact-info a:hover {
        text-decoration: underline;
      }

      .hours-list {
        font-size: 0.9rem;
        color: var(--gray-700);
      }

      .hours-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 0.5rem;
      }

      .hours-row strong {
        color: var(--gray-900);
        font-weight: 600;
      }

      .reassurance-list {
        list-style: none;
      }

      .reassurance-list li {
        display: flex;
        gap: 0.6rem;
        margin-bottom: 0.8rem;
        font-size: 0.9rem;
        color: var(--gray-700);
      }

      .reassurance-list svg {
        width: 16px;
        height: 16px;
        color: var(--green);
        flex-shrink: 0;
        margin-top: 2px;
      }

      /* Footer */
      .dg-footer {
        background: var(--gray-900);
        color: rgba(255,255,255,0.9);
        padding: 2rem 1.5rem;
        text-align: center;
        font-size: 0.85rem;
        margin-top: 3rem;
      }

      .dg-footer a {
        color: rgba(255,255,255,0.9);
        text-decoration: none;
      }

      .dg-footer a:hover {
        text-decoration: underline;
      }

      /* Responsive */
      @media (max-width: 768px) {
        .dg-layout {
          grid-template-columns: 1fr;
        }

        .dg-hero h1 {
          font-size: 1.5rem;
        }

        .dg-trust {
          grid-template-columns: 1fr;
          gap: 1rem;
        }

        .form-row {
          grid-template-columns: 1fr;
          gap: 1.5rem;
        }

        .dg-header-inner {
          flex-direction: column;
          gap: 1rem;
          align-items: flex-start;
        }

        .dg-phone {
          font-size: 0.85rem;
        }
      }

      .hidden {
        display: none;
      }
    </style>
  </head>
  <body>
    <!-- Header -->
    <header class="dg-header">
      <div class="dg-header-inner">
        <a href="/" class="dg-logo">
          <svg viewBox="0 0 28 28" fill="none">
            <rect width="28" height="28" rx="6" fill="#1e5ea6"/>
            <path d="M6 19V9l4.5 5L15 9v10M15 9l4.5 5L24 9v10" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          MM Sécurité
        </a>
        <a href="tel:+33688766648" class="dg-phone">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
          </svg>
          06 88 76 66 48
        </a>
      </div>
    </header>

    <!-- Hero -->
    <section class="dg-hero">
      <h1>Demandez votre devis gratuit</h1>
      <p>Réponse personnalisée sous 48 heures, sans engagement.</p>
    </section>

    <!-- Trust strip -->
    <div class="dg-trust">
      <div class="dg-trust-item">
        <strong>Gratuit & sans engagement</strong>
        <span>Aucune obligation d'achat</span>
      </div>
      <div class="dg-trust-item">
        <strong>Réponse sous 48h</strong>
        <span>Devis détaillé et personnalisé</span>
      </div>
      <div class="dg-trust-item">
        <strong>Technicien local</strong>
        <span>Basé à Metz</span>
      </div>
    </div>

    <!-- Main content -->
    <div class="dg-container">
      <div class="dg-layout">
        <!-- Form section -->
        <div class="dg-form-section">
          <div class="dg-form">
            <form class="dg-form" id="contact-form">
              <input type="hidden" name="access_key" value="5c0597af-80a9-48ba-b856-5c436e39ea74" />
              <input type="hidden" name="subject" value="Demande de devis depuis mm-securite.fr" />
              <input type="hidden" name="from_name" value="MM Sécurité - Devis" />
              <input type="hidden" name="replyto" value="email" />
              <input type="hidden" name="autoreply" value="Bonjour, merci pour votre demande de devis ! Je l'ai bien reçue et je vous recontacte sous 48 heures avec un devis personnalisé. À très vite — Marc Muller, MM Sécurité | 06 88 76 66 48" />
              <input type="checkbox" name="botcheck" class="hidden" style="display:none" />

              <div class="form-row">
                <div class="form-group">
                  <label for="nom">Nom *</label>
                  <input type="text" id="nom" name="nom" placeholder="Votre nom" required autocomplete="name" />
                </div>
                <div class="form-group">
                  <label for="telephone">Téléphone *</label>
                  <input type="tel" id="telephone" name="telephone" placeholder="06 12 34 56 78" required autocomplete="tel" />
                </div>
              </div>

              <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" placeholder="vous@exemple.fr" autocomplete="email" />
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label for="commerce">Type de commerce</label>
                  <select id="commerce" name="commerce">
                    <option value="">-- Votre activité --</option>
                    <option value="boulangerie">Boulangerie / Pâtisserie</option>
                    <option value="restaurant">Restaurant / Bar</option>
                    <option value="salon">Salon de coiffure / beauté</option>
                    <option value="boutique">Boutique / Magasin</option>
                    <option value="pharmacie">Pharmacie</option>
                    <option value="cabinet">Cabinet médical</option>
                    <option value="hotel">Hôtel / Hébergement</option>
                    <option value="salle-sport">Salle de sport</option>
                    <option value="bureau">Bureau / Coworking</option>
                    <option value="autre">Autre</option>
                  </select>
                </div>
                <div class="form-group">
                  <label for="service">Service souhaité</label>
                  <select id="service" name="service">
                    <option value="">-- Service --</option>
                    <option value="alarme-intrusion">Alarme intrusion</option>
                    <option value="alarme-incendie">Alarme incendie / SSI</option>
                    <option value="videosurveillance">Vidéosurveillance</option>
                    <option value="controle-acces">Contrôle d'accès</option>
                    <option value="plan-evacuation">Plan d'évacuation</option>
                    <option value="mise-en-conformite">Mise en conformité ERP</option>
                    <option value="pack-complet">Pack complet sécurité</option>
                    <option value="sous-traitance">Sous-traitance (pro)</option>
                  </select>
                </div>
              </div>

              <div class="form-group">
                <label for="message">Décrivez votre besoin *</label>
                <textarea id="message" name="message" placeholder="Décrivez votre projet, la taille de vos locaux, vos contraintes…" required></textarea>
              </div>

              <p class="form-rgpd" style="font-size:0.8rem;color:#6b7280;margin-bottom:1rem;line-height:1.5;">
                En soumettant ce formulaire, vous acceptez que vos données soient traitées conformément à notre
                <a href="/politique-de-confidentialite" style="color:#1e5ea6;text-decoration:underline;">politique de confidentialité</a>.
                Vos données ne seront jamais partagées avec des tiers.
              </p>
              <button type="submit" class="btn btn-primary" id="submit-btn">
                <span class="btn-text">Envoyer ma demande de devis</span>
                <span class="btn-loading" style="display:none">Envoi en cours…</span>
              </button>
              <p class="form-note">Gratuit & sans engagement — réponse sous 48h</p>
            </form>

            <!-- Success message -->
            <div class="form-success" id="form-success" role="status" aria-live="polite">
              <div class="success-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <h3>Devis demandé !</h3>
              <p>Merci pour votre demande. Je vous recontacte sous <strong>48 heures</strong>.</p>
              <button class="btn btn-ghost" id="reset-form">Envoyer un autre devis</button>
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="dg-sidebar">
          <!-- Contact card -->
          <div class="sidebar-card">
            <h3>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
              </svg>
              Marc Muller
            </h3>
            <div class="contact-info">
              <strong>Technicien sécurité</strong>
              <a href="tel:+33688766648">06 88 76 66 48</a>
              <a href="mailto:marc@muller.im">marc@muller.im</a>
              Metz, Moselle
            </div>
          </div>

          <!-- Hours card -->
          <div class="sidebar-card">
            <h3>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
              Disponibilités
            </h3>
            <div class="hours-list">
              <div class="hours-row">
                <span>Lundi – Vendredi</span>
                <strong>8h – 18h</strong>
              </div>
              <div class="hours-row">
                <span>Samedi</span>
                <strong>Sur RDV</strong>
              </div>
              <div class="hours-row">
                <span>Urgence</span>
                <strong>Me contacter</strong>
              </div>
            </div>
          </div>

          <!-- Reassurance -->
          <div class="sidebar-card">
            <h3>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 22C6.477 22 2 17.523 2 12S6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
                <path d="M10 14.5L8 12.5M10 14.5L14 10.5"/>
              </svg>
              Pourquoi choisir MM Sécurité ?
            </h3>
            <ul class="reassurance-list">
              <li>
                <svg viewBox="0 0 24 24" fill="currentColor">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                </svg>
                Devis sans engagement
              </li>
              <li>
                <svg viewBox="0 0 24 24" fill="currentColor">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                </svg>
                Réponse sous 48h
              </li>
              <li>
                <svg viewBox="0 0 24 24" fill="currentColor">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                </svg>
                Interlocuteur unique
              </li>
            </ul>
          </div>
        </aside>
      </div>
    </div>

    <!-- Footer -->
    <footer class="dg-footer">
      <p>&copy; 2026 MM Sécurité — Marc Muller EI | <a href="/">Accueil</a> | <a href="/a-propos">À propos</a> | <a href="/mentions-legales">Mentions légales</a> | <a href="/politique-de-confidentialite">Politique de confidentialité</a></p>
    </footer>

    <script>
      const contactForm = document.getElementById('contact-form') as HTMLFormElement;
      const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
      const formSuccess = document.getElementById('form-success') as HTMLElement;
      const resetBtn = document.getElementById('reset-form') as HTMLButtonElement;

      if (contactForm) {
        contactForm.addEventListener('submit', async (e) => {
          e.preventDefault();

          const btnText = submitBtn.querySelector('.btn-text') as HTMLElement;
          const btnLoading = submitBtn.querySelector('.btn-loading') as HTMLElement;

          // Loading state
          btnText.style.display = 'none';
          btnLoading.style.display = 'inline';
          submitBtn.setAttribute('disabled', 'true');
          submitBtn.style.opacity = '0.7';

          try {
            const formData = new FormData(contactForm);
            const res = await fetch('https://api.web3forms.com/submit', {
              method: 'POST',
              body: formData,
            });
            const data = await res.json();

            if (data.success) {
              // Redirect to thank you page
              window.location.href = '/merci';
            } else {
              throw new Error('Erreur serveur');
            }
          } catch (err) {
            // Reset button
            btnText.style.display = 'inline';
            btnLoading.style.display = 'none';
            submitBtn.removeAttribute('disabled');
            submitBtn.style.opacity = '1';

            alert('Une erreur est survenue. Veuillez réessayer ou me contacter directement au 06 88 76 66 48.');
          }
        });

        // Reset form
        if (resetBtn) {
          resetBtn.addEventListener('click', () => {
            contactForm.reset();
            contactForm.style.display = 'flex';
            formSuccess.style.display = 'none';

            const btnText = submitBtn.querySelector('.btn-text') as HTMLElement;
            const btnLoading = submitBtn.querySelector('.btn-loading') as HTMLElement;
            btnText.style.display = 'inline';
            btnLoading.style.display = 'none';
            submitBtn.removeAttribute('disabled');
            submitBtn.style.opacity = '1';
          });
        }
      }
    </script>
  </body>
</html>
