---
// SHIM CLIENT — monte le panel /admin via AdminIsland (wrapper site-owned généré
// par cms-engine-scaffold : importe CmsApp + les modules déclarés, les injecte en
// prop ; config reste sérialisable). Seul fichier qui connait la config.
import '@marc/cms-engine/cms.css';
import AdminIsland from '../components/AdminIsland';
import cmsConfig from '../../cms.config';

const cmsLocale = (cmsConfig as { locale?: 'fr' | 'en' }).locale === 'en' ? 'en' : 'fr';
const adminTitle = cmsLocale === 'en' ? 'Admin' : 'Administration';
---

<!doctype html>
<html lang={cmsLocale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{cmsConfig.siteName} — {adminTitle}</title>
  </head>
  <body>
    <script define:vars={{ cfg: cmsConfig }} is:inline>
      window.__cmsConfig = cfg;
    </script>
    <AdminIsland config={cmsConfig} client:only="react" />
  </body>
</html>
