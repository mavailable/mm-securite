---
// SHIM CLIENT — monte le panel /admin via AdminIsland (wrapper site-owned généré
// par cms-engine-scaffold : importe CmsApp + les modules déclarés, les injecte en
// prop ; config reste sérialisable). Seul fichier qui connait la config.
import '@marc/cms-engine/cms.css';
import AdminIsland from '../components/AdminIsland';
import cmsConfig from '../../cms.config';

const cmsLocale = (cmsConfig as { locale?: 'fr' | 'en' }).locale === 'en' ? 'en' : 'fr';
const adminTitle = cmsLocale === 'en' ? 'Admin' : 'Administration';
---

<!doctype html>
<html lang={cmsLocale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" /> {/* favicon du site */}
    <title>{cmsConfig.siteName} — {adminTitle}</title>
    <style>
      /* Polices du site pour le branding admin (adminTheme.fontBody/fontHeading).
         Fichiers locaux /fonts/, mêmes woff2 que le site public. */
      @font-face { font-family: 'Inter'; src: url('/fonts/inter-latin-400-normal.woff2') format('woff2'); font-weight: 400; font-display: swap; }
      @font-face { font-family: 'Inter'; src: url('/fonts/inter-latin-500-normal.woff2') format('woff2'); font-weight: 500; font-display: swap; }
      @font-face { font-family: 'Inter'; src: url('/fonts/inter-latin-600-normal.woff2') format('woff2'); font-weight: 600; font-display: swap; }
      @font-face { font-family: 'Inter'; src: url('/fonts/inter-latin-700-normal.woff2') format('woff2'); font-weight: 700; font-display: swap; }
      @font-face { font-family: 'Outfit'; src: url('/fonts/outfit-latin-600-normal.woff2') format('woff2'); font-weight: 600; font-display: swap; }
      @font-face { font-family: 'Outfit'; src: url('/fonts/outfit-latin-700-normal.woff2') format('woff2'); font-weight: 700; font-display: swap; }
    </style>
  </head>
  <body>
    <script define:vars={{ cfg: cmsConfig }} is:inline>
      window.__cmsConfig = cfg;
    </script>
    <AdminIsland config={cmsConfig} client:only="react" />
  </body>
</html>
